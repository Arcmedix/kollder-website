---
pagination:
  data: langs
  size: 1
  alias: lang
langs:
  - fr
  - en
permalink: "/{{ lang }}/monitor/"
layout: false
---
<!DOCTYPE html>
<html lang="{{ lang }}">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
{% if lang == "fr" %}
<title>Moniteur de risque — Coup de chaleur d'effort par département — Kollder</title>
<meta name="description" content="Outil de surveillance du risque de coup de chaleur d'effort (EHS) par département. WBGT en temps réel, protocoles d'urgence et alertes personnalisées selon votre profil.">
{% else %}
<title>Exertional Heat Stroke Risk Monitor by Department — Kollder</title>
<meta name="description" content="Real-time exertional heat stroke (EHS) risk monitoring by department. Live WBGT, emergency protocols and personalised alerts for your profile.">
{% endif %}
<link rel="icon" href="/favicon.ico">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root {
  --black: #0f0f0d; --ink: #1a1a17; --white: #faf9f7;
  --cream: #f0ece4; --beige: #e8e0d4; --sand: #c8bfb0;
  --muted: #8a8278; --border: rgba(26,26,23,0.1);
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
body { background: var(--white); color: var(--ink); font-family: 'DM Sans', sans-serif; font-weight: 300; line-height: 1.7; }

nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  display: flex; justify-content: space-between; align-items: center;
  padding: 14px 56px; background: rgba(255,255,255,0.95);
  backdrop-filter: blur(20px); border-bottom: 1px solid rgba(0,0,0,0.08);
}
.nav-brand img { height: 52px; width: auto; display: block; }
.nav-right { display: flex; align-items: center; gap: 24px; }
.nav-back {
  font-size: 13px; font-weight: 500; color: var(--muted);
  text-decoration: none; letter-spacing: 0.06em;
  display: flex; align-items: center; gap: 8px; transition: color .2s;
}
.nav-back:hover { color: var(--ink); }
.lang-toggle { display: flex; border: 1px solid var(--border); }
.lang-btn {
  background: none; border: none; font-family: 'DM Sans', sans-serif;
  font-size: 12px; font-weight: 500; letter-spacing: 0.1em;
  padding: 6px 14px; cursor: pointer; color: var(--muted); transition: all .2s;
  text-decoration: none; display: inline-block;
}
.lang-btn.active { background: var(--black); color: var(--white); }

/* Hamburger */
.ham-btn {
  display: none; flex-direction: column; justify-content: center;
  gap: 5px; background: none; border: none; cursor: pointer;
  padding: 4px; z-index: 200;
}
.ham-btn span {
  display: block; width: 22px; height: 2px;
  background: var(--ink); transition: all .25s;
}
.ham-btn.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.ham-btn.open span:nth-child(2) { opacity: 0; }
.ham-btn.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

/* Mobile overlay */
.nav-overlay {
  display: none; position: fixed; inset: 0; z-index: 150;
  background: var(--white); flex-direction: column;
  padding: 90px 32px 40px;
}
.nav-overlay.open { display: flex; }
.nav-overlay-links { display: flex; flex-direction: column; gap: 8px; flex: 1; }
.nav-overlay-link {
  font-size: 22px; font-weight: 400; color: var(--ink);
  text-decoration: none; padding: 14px 0;
  border-bottom: 1px solid var(--border);
  display: flex; align-items: center; justify-content: space-between;
  font-family: 'DM Serif Display', serif;
}
.nav-overlay-link:last-child { border-bottom: none; }
.nav-overlay-cta {
  display: inline-flex; align-items: center; gap: 10px; margin-top: 32px;
  background: var(--black); color: var(--white); text-decoration: none;
  font-size: 13px; font-weight: 500; letter-spacing: 0.1em;
  text-transform: uppercase; padding: 16px 28px; align-self: flex-start;
}
.nav-overlay-lang {
  display: flex; gap: 0; border: 1px solid var(--border);
  margin-top: 24px; align-self: flex-start;
}
.nav-overlay-lang a {
  font-size: 12px; font-weight: 500; letter-spacing: 0.1em;
  padding: 8px 16px; text-decoration: none; color: var(--muted);
}
.nav-overlay-lang a.active { background: var(--black); color: var(--white); }
@keyframes pulse-dot {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(0.8); }
}

/* HERO */
.hero { padding: 140px 56px 60px; background: var(--black); color: var(--white); }
.hero-inner { max-width: 1240px; margin: 0 auto; text-align: center; }
.hero-label {
  font-size: 11px; font-weight: 500; letter-spacing: 0.2em;
  text-transform: uppercase; color: var(--muted); margin-bottom: 20px;
}
.hero h1 {
  font-family: 'DM Serif Display', serif;
  font-size: clamp(28px, 4vw, 48px); font-weight: 400;
  line-height: 1.1; margin-bottom: 20px;
}
.hero h1 em { font-style: normal; color: #E24B4A; }
.hero-sub {
  font-size: 15px; color: rgba(250,249,247,0.5);
  max-width: 560px; margin: 0 auto; line-height: 1.7; font-weight: 300;
}
.hero-pill {
  display: inline-flex; align-items: center; gap: 10px;
  margin-top: 28px; border: 1px solid rgba(255,255,255,0.1);
  border-radius: 24px; padding: 7px 20px; font-size: 13px; color: rgba(250,249,247,0.45);
}
.hero-pill strong { color: var(--white); font-weight: 500; }

/* PAGE */
.page { max-width: 880px; margin: 0 auto; padding: 2.5rem 2rem 5rem; }

/* SELECTOR */
.selector-row { display: flex; gap: 12px; align-items: flex-end; margin-bottom: 1.75rem; flex-wrap: wrap; }
.selector-row label {
  font-size: 11px; font-weight: 500; letter-spacing: 0.1em;
  text-transform: uppercase; color: var(--muted); margin-bottom: 5px; display: block;
}
.selector-row select {
  font-family: 'DM Sans', sans-serif; font-size: 14px; font-weight: 300;
  padding: 10px 14px; border: 1px solid var(--beige); border-radius: 4px;
  background: var(--white); color: var(--ink); min-width: 230px; cursor: pointer;
}
.selector-row select:focus { outline: 2px solid var(--ink); outline-offset: 1px; }
.btn-refresh {
  font-family: 'DM Sans', sans-serif; font-size: 13px; font-weight: 500;
  padding: 10px 18px; border: 1px solid var(--beige); border-radius: 4px;
  background: var(--white); color: var(--ink); cursor: pointer;
  letter-spacing: 0.04em; transition: background .15s;
}
.btn-refresh:hover { background: var(--cream); }

#km-loading { padding: 3rem; text-align: center; font-size: 14px; color: var(--muted); display: none; }

/* STATS */
.stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 10px; margin-bottom: 1.25rem; }
.stat-card { background: var(--cream); border-radius: 4px; padding: 16px 18px; }
.stat-card.stat-featured { border: 1.5px solid var(--sand); position: relative; }
.stat-acsm {
  position: absolute; top: 10px; right: 12px;
  font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase; color: #E24B4A; font-weight: 500;
}
.stat-label { font-size: 11px; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted); margin-bottom: 6px; }
.stat-value { font-size: 28px; font-weight: 400; color: var(--black); line-height: 1; }
.stat-value.serif { font-family: 'DM Serif Display', serif; }
.stat-unit { font-size: 13px; color: var(--muted); margin-left: 2px; }
.stat-note { font-size: 11px; color: var(--muted); margin-top: 5px; font-weight: 300; }

/* RISK BANNER */
.risk-banner {
  border-radius: 4px; padding: 20px 22px; margin-bottom: 1.75rem;
  border-left: 4px solid; display: flex; gap: 16px; align-items: flex-start;
}
.risk-banner-level { font-family: 'DM Serif Display', serif; font-size: 20px; font-weight: 400; margin-bottom: 5px; }
.risk-banner-desc { font-size: 13px; line-height: 1.65; font-weight: 300; }
.risk-banner-protocol {
  margin-top: 10px; font-size: 11px; font-weight: 500; letter-spacing: 0.06em;
  text-transform: uppercase; padding: 4px 12px; border-radius: 3px; display: inline-block;
}

/* TABS */
.tabs { display: flex; border-bottom: 1px solid var(--border); margin-bottom: 1.75rem; }
.tab {
  font-family: 'DM Sans', sans-serif; font-size: 13px; font-weight: 500;
  padding: 10px 20px; border: none; background: none; color: var(--muted);
  cursor: pointer; border-bottom: 2px solid transparent; margin-bottom: -1px;
  letter-spacing: 0.04em; transition: color .15s;
}
.tab.active { color: var(--ink); border-bottom-color: var(--ink); }
.tab:hover { color: var(--ink); }
.panel { display: none; }
.panel.active { display: block; }

/* FORECAST */
.forecast-grid { display: grid; grid-template-columns: repeat(7, minmax(0, 1fr)); gap: 8px; }
.fc-card { background: var(--cream); border-radius: 4px; padding: 12px 6px; text-align: center; }
.fc-day { font-size: 10px; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted); margin-bottom: 7px; }
.fc-temp { font-size: 17px; font-weight: 400; color: var(--black); }
.fc-hum { font-size: 10px; color: var(--muted); margin-top: 2px; font-weight: 300; }
.fc-wbgt { font-size: 11px; font-weight: 500; margin-top: 6px; }
.fc-dot { width: 7px; height: 7px; border-radius: 50%; margin: 5px auto 0; }

/* RECOS */
.recos { display: flex; flex-direction: column; gap: 10px; }
.reco-card { background: var(--cream); border-radius: 4px; padding: 16px 18px; display: flex; gap: 14px; }
.reco-card.reco-kollder { border-left: 3px solid var(--black); background: var(--beige); }
.reco-icon { font-size: 18px; flex-shrink: 0; margin-top: 1px; }
.reco-title { font-size: 13px; font-weight: 500; color: var(--black); margin-bottom: 3px; letter-spacing: 0.02em; }
.reco-kollder .reco-title::after { content: " — Kollder"; font-weight: 300; color: var(--muted); }
.reco-body { font-size: 13px; color: var(--ink); line-height: 1.65; font-weight: 300; }

/* ALERT */
.alert-section { margin-top: 2.5rem; border: 1px solid var(--beige); border-radius: 4px; overflow: hidden; }
.alert-header { background: var(--black); color: var(--white); padding: 18px 22px; }
.alert-header-title { font-family: 'DM Serif Display', serif; font-size: 18px; font-weight: 400; margin-bottom: 4px; }
.alert-header-sub { font-size: 13px; color: rgba(250,249,247,0.45); font-weight: 300; }
.alert-body { padding: 22px; }
.alert-form { display: flex; flex-direction: column; gap: 16px; }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
.form-group { display: flex; flex-direction: column; gap: 5px; }
.form-group label { font-size: 11px; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); }
.form-group input, .form-group select {
  font-family: 'DM Sans', sans-serif; font-size: 14px; font-weight: 300;
  padding: 10px 12px; border: 1px solid var(--beige); border-radius: 4px;
  background: var(--white); color: var(--ink);
}
.form-group input:focus, .form-group select:focus { outline: 2px solid var(--ink); outline-offset: 1px; }
.threshold-pills { display: flex; gap: 8px; flex-wrap: wrap; }
.pill {
  font-family: 'DM Sans', sans-serif; font-size: 12px; font-weight: 400;
  padding: 6px 14px; border-radius: 20px; border: 1px solid var(--beige);
  background: var(--white); color: var(--muted); cursor: pointer; transition: all .15s;
}
.pill.active { border-color: var(--ink); color: var(--ink); font-weight: 500; }
.pill.pill-mod.active { border-color: #EF9F27; background: #FAEEDA; color: #633806; }
.pill.pill-hi.active  { border-color: #D85A30; background: #FAECE7; color: #712B13; }
.pill.pill-cr.active  { border-color: #E24B4A; background: #FCEBEB; color: #791F1F; }
.btn-subscribe {
  font-family: 'DM Sans', sans-serif; font-size: 13px; font-weight: 500;
  padding: 12px 24px; background: var(--black); color: var(--white);
  border: none; border-radius: 4px; cursor: pointer; letter-spacing: 0.04em;
  transition: background .15s;
}
.btn-subscribe:hover { background: var(--ink); }
.alert-success {
  background: #EAF3DE; border-radius: 4px; padding: 16px;
  text-align: center; font-size: 14px; color: #27500A; display: none; font-weight: 300;
}
.alert-disclaimer { font-size: 11px; color: var(--muted); line-height: 1.6; font-weight: 300; }

.km-footer {
  margin-top: 2rem; padding-top: 1rem; border-top: 1px solid var(--border);
  display: flex; justify-content: space-between;
  font-size: 11px; color: var(--muted); font-weight: 300; flex-wrap: wrap; gap: 4px;
}

/* FOOTER */
footer { background: #000; border-top: 1px solid rgba(255,255,255,0.08); padding: 40px 56px; }
.footer-inner {
  max-width: 1240px; margin: 0 auto;
  display: flex; justify-content: space-between; align-items: center; gap: 24px; flex-wrap: wrap;
}
.footer-brand img { height: 52px; width: auto; display: block; filter: invert(1); }
.footer-note { font-size: 12px; color: rgba(250,249,247,0.25); letter-spacing: 0.04em; }

@media (max-width: 768px) {
  nav { padding: 14px 24px; }
  .nav-right { display: none; }
  .ham-btn { display: flex; }
  .hero { padding: 100px 24px 40px; }
  .page { padding: 1.5rem 1.25rem 4rem; }
  .form-row { grid-template-columns: 1fr; }
  .forecast-grid { grid-template-columns: repeat(4, minmax(0, 1fr)); }
  .forecast-grid .fc-card:nth-child(n+5) { display: none; }
  footer { padding: 32px 24px; }
}
</style>
</head>
<body>

<nav>
  <div class="nav-brand">
    <a href="/{{ lang }}/"><img src="/logo-kollder.png" alt="Kollder"></a>
  </div>
  <div class="nav-right">
    <a href="{% if lang == 'en' %}/en/partners/{% else %}/fr/distributeurs/{% endif %}" class="nav-back" style="font-size:13px;font-weight:500;letter-spacing:.06em;color:var(--muted);text-decoration:none;transition:color .2s;">
      {% if lang == "fr" %}Distributeurs{% else %}Partners{% endif %}
    </a>
    <a href="{% if lang == 'en' %}/blog/?lang=en{% else %}/blog/?lang=fr{% endif %}" class="nav-back" style="font-size:13px;font-weight:500;letter-spacing:.06em;color:var(--muted);text-decoration:none;transition:color .2s;">
      {% if lang == "fr" %}Ressources{% else %}Resources{% endif %}
    </a>
    <a href="/{{ lang }}/monitor/" class="nav-back" style="display:inline-flex;align-items:center;gap:5px;font-size:13px;font-weight:500;letter-spacing:.06em;color:var(--ink);text-decoration:none;">
      <span style="width:7px;height:7px;border-radius:50%;background:#e85c3a;display:inline-block;animation:pulse-dot 2s ease-in-out infinite;"></span>
      {% if lang == "fr" %}Moniteur EHS{% else %}EHS Monitor{% endif %}
    </a>
    <div class="lang-toggle">
      <a class="lang-btn {% if lang == 'fr' %}active{% endif %}" href="/fr/monitor/">FR</a>
      <a class="lang-btn {% if lang == 'en' %}active{% endif %}" href="/en/monitor/">EN</a>
    </div>
    <a href="/{{ lang }}/#contact" style="display:inline-flex;align-items:center;gap:10px;background:var(--black);color:var(--white);text-decoration:none;font-size:12px;font-weight:500;letter-spacing:.1em;text-transform:uppercase;padding:10px 20px;">
      {% if lang == "fr" %}Obtenir un devis{% else %}Get a quote{% endif %}
    </a>
  </div>
  <button class="ham-btn" id="hamBtn" aria-label="Menu">
    <span></span><span></span><span></span>
  </button>
</nav>

<!-- Mobile overlay -->
<div class="nav-overlay" id="navOverlay">
  <div class="nav-overlay-links">
    <a class="nav-overlay-link" href="/{{ lang }}/">
      <span>{% if lang == "fr" %}Accueil{% else %}Home{% endif %}</span>
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
    </a>
    <a class="nav-overlay-link" href="{% if lang == 'en' %}/en/partners/{% else %}/fr/distributeurs/{% endif %}">
      <span>{% if lang == "fr" %}Distributeurs{% else %}Partners{% endif %}</span>
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
    </a>
    <a class="nav-overlay-link" href="{% if lang == 'en' %}/blog/?lang=en{% else %}/blog/?lang=fr{% endif %}">
      <span>{% if lang == "fr" %}Ressources{% else %}Resources{% endif %}</span>
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
    </a>
    <a class="nav-overlay-link" href="/{{ lang }}/monitor/">
      <span>{% if lang == "fr" %}Moniteur EHS{% else %}EHS Monitor{% endif %} <span style="display:inline-block;width:7px;height:7px;border-radius:50%;background:#e85c3a;margin-left:4px;vertical-align:middle;"></span></span>
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
    </a>
  </div>
  <a class="nav-overlay-cta" href="/{{ lang }}/#contact">
    <span>{% if lang == "fr" %}Obtenir un devis{% else %}Get a quote{% endif %}</span>
    <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
  </a>
  <div class="nav-overlay-lang">
    <a class="{% if lang == 'fr' %}active{% endif %}" href="/fr/monitor/">FR</a>
    <a class="{% if lang == 'en' %}active{% endif %}" href="/en/monitor/">EN</a>
  </div>
</div>

<div class="hero">
  <div class="hero-inner">
    <p class="hero-label">Kollder — Outil médical d'aide à la décision</p>
    {% if lang == "fr" %}
    <h1>Risque de <em>coup de chaleur d'effort</em><br>par département</h1>
    <p class="hero-sub">Le WBGT est l'indice de référence ACSM pour évaluer le risque d'hyperthermie d'effort. Au-delà de 28°C, chaque minute sans refroidissement actif compte.</p>
    {% else %}
    <h1><em>Exertional heat stroke</em> risk<br>by department</h1>
    <p class="hero-sub">WBGT is the ACSM reference index for exertional heat stroke risk. Above 28°C, every minute without active cooling counts.</p>
    {% endif %}
    <div class="hero-pill">
      <strong id="hero-wbgt">--°C WBGT</strong>
      <span id="hero-dept-name">--</span>
    </div>
  </div>
</div>

<main class="page">

  <div class="selector-row">
    <div>
      <label for="km-select">{% if lang == "fr" %}Département{% else %}Department{% endif %}</label>
      <select id="km-select"></select>
    </div>
    <button class="btn-refresh" id="km-refresh">
      ↻ {% if lang == "fr" %}Actualiser{% else %}Refresh{% endif %}
    </button>
  </div>

  <div id="km-loading">{% if lang == "fr" %}Chargement des données météo...{% else %}Loading weather data...{% endif %}</div>

  <div id="km-main">
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-label">{% if lang == "fr" %}Température{% else %}Temperature{% endif %}</div>
        <div class="stat-value" id="v-temp">--<span class="stat-unit">°C</span></div>
        <div class="stat-note">{% if lang == "fr" %}Air ambiant{% else %}Ambient air{% endif %}</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">{% if lang == "fr" %}Humidité{% else %}Humidity{% endif %}</div>
        <div class="stat-value" id="v-hum">--<span class="stat-unit">%</span></div>
        <div class="stat-note">{% if lang == "fr" %}Relative{% else %}Relative{% endif %}</div>
      </div>
      <div class="stat-card stat-featured">
        <span class="stat-acsm">ACSM REF.</span>
        <div class="stat-label">WBGT</div>
        <div class="stat-value serif" id="v-wbgt">--<span class="stat-unit">°C</span></div>
        <div class="stat-note">{% if lang == "fr" %}Indice thermique EHS{% else %}EHS heat index{% endif %}</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">{% if lang == "fr" %}Vent{% else %}Wind{% endif %}</div>
        <div class="stat-value" id="v-wind">--<span class="stat-unit">km/h</span></div>
        <div class="stat-note">{% if lang == "fr" %}Vitesse{% else %}Speed{% endif %}</div>
      </div>
    </div>

    <div class="risk-banner" id="km-banner">
      <div style="flex:1">
        <div class="risk-banner-level" id="b-level">—</div>
        <div class="risk-banner-desc" id="b-desc">—</div>
        <div class="risk-banner-protocol" id="b-protocol" style="display:none"></div>
      </div>
    </div>

    <div class="tabs">
      <button class="tab active" data-tab="forecast">{% if lang == "fr" %}Prévision 7 jours{% else %}7-day forecast{% endif %}</button>
      <button class="tab" data-tab="recos">{% if lang == "fr" %}Protocoles d'urgence{% else %}Emergency protocols{% endif %}</button>
    </div>

    <div id="tab-forecast" class="panel active">
      <div class="forecast-grid" id="km-fc"></div>
    </div>

    <div id="tab-recos" class="panel">
      <div class="recos" id="km-recos"></div>
    </div>

    <div class="alert-section" id="km-alert-section" style="display:none">
      <div class="alert-header">
        <div class="alert-header-title" id="alert-header-title">—</div>
        <div class="alert-header-sub" id="alert-header-sub">—</div>
      </div>
      <div class="alert-body">
        <form class="alert-form" id="km-alert-form" action="https://formspree.io/f/mykovqeg" method="POST">
          <input type="hidden" name="_subject" id="form-subject" value="">
          <input type="hidden" name="department" id="form-dept" value="">
          <input type="hidden" name="wbgt" id="form-wbgt" value="">
          <input type="hidden" name="risk_level" id="form-risk" value="">
          <input type="hidden" name="threshold" id="form-threshold" value="modere">
          <input type="hidden" name="lang" value="{{ lang }}">
          <div class="form-row">
            <div class="form-group">
              <label for="form-email">{% if lang == "fr" %}Email professionnel{% else %}Professional email{% endif %}</label>
              <input type="email" id="form-email" name="email" placeholder="prenom@organisation.fr" required>
            </div>
            <div class="form-group">
              <label for="form-profile">{% if lang == "fr" %}Votre profil{% else %}Your profile{% endif %}</label>
              <select id="form-profile" name="profile">
                {% if lang == "fr" %}
                <option value="organisateur">Organisateur d'événement sportif</option>
                <option value="sdis">SDIS / Sapeurs-pompiers</option>
                <option value="ehs">Responsable EHS / HSE industrie</option>
                <option value="medecin">Médecin urgentiste / SMUR</option>
                <option value="militaire">Médecin militaire / SSSM</option>
                <option value="autre">Autre</option>
                {% else %}
                <option value="organisateur">Sports event organiser</option>
                <option value="sdis">Fire & Rescue / EMS</option>
                <option value="ehs">EHS / HSE manager</option>
                <option value="medecin">Emergency physician</option>
                <option value="militaire">Military medical officer</option>
                <option value="autre">Other</option>
                {% endif %}
              </select>
            </div>
          </div>
          <div class="form-group">
            <label>{% if lang == "fr" %}Seuil d'alerte{% else %}Alert threshold{% endif %}</label>
            <div class="threshold-pills">
              <button type="button" class="pill pill-mod active" data-val="modere" onclick="setThreshold(this,'modere')">{% if lang == "fr" %}Dès risque Modéré (WBGT > 28°C){% else %}From Moderate risk (WBGT > 28°C){% endif %}</button>
              <button type="button" class="pill pill-hi" data-val="eleve" onclick="setThreshold(this,'eleve')">{% if lang == "fr" %}Dès risque Élevé (WBGT > 31°C){% else %}From High risk (WBGT > 31°C){% endif %}</button>
              <button type="button" class="pill pill-cr" data-val="critique" onclick="setThreshold(this,'critique')">{% if lang == "fr" %}Critique uniquement (WBGT > 35°C){% else %}Critical only (WBGT > 35°C){% endif %}</button>
            </div>
          </div>
          <div style="display:flex;gap:14px;align-items:center;flex-wrap:wrap">
            <button type="submit" class="btn-subscribe">{% if lang == "fr" %}Activer les alertes EHS →{% else %}Activate EHS alerts →{% endif %}</button>
            <div class="alert-disclaimer">{% if lang == "fr" %}Email unique. Pas de newsletter. Alertes EHS uniquement pour ce département.{% else %}Single email. No newsletter. EHS alerts only for this department.{% endif %}</div>
          </div>
        </form>
        <div class="alert-success" id="alert-success">
          {% if lang == "fr" %}✓ Alertes EHS activées pour ce département.{% else %}✓ EHS alerts activated for this department.{% endif %}
        </div>
      </div>
    </div>

    <div class="km-footer">
      <span>Open-Meteo · WBGT méthode Liljegren approx. · Seuils ACSM Expert Consensus 2023</span>
      <span id="km-updated">—</span>
    </div>
  </div>

</main>

<footer>
  <div class="footer-inner">
    <div class="footer-brand"><img src="/logo-kollder.png" alt="Kollder"></div>
    <div class="footer-note">Emergency Cooling. Anywhere.</div>
  </div>
</footer>

