  {c:"17",n:"Charente-Maritime",lat:45.8,lon:-0.8},{c:"18",n:"Cher",lat:47.1,lon:2.5},
  {c:"19",n:"Corrèze",lat:45.3,lon:1.8},{c:"21",n:"Côte-d'Or",lat:47.4,lon:4.8},
  {c:"22",n:"Côtes-d'Armor",lat:48.5,lon:-2.9},{c:"23",n:"Creuse",lat:46.0,lon:2.0},
  {c:"24",n:"Dordogne",lat:45.1,lon:0.7},{c:"25",n:"Doubs",lat:47.2,lon:6.4},
  {c:"26",n:"Drôme",lat:44.7,lon:5.0},{c:"27",n:"Eure",lat:49.1,lon:1.2},
  {c:"28",n:"Eure-et-Loir",lat:48.4,lon:1.4},{c:"29",n:"Finistère",lat:48.2,lon:-4.1},
  {c:"30",n:"Gard",lat:44.0,lon:4.3},{c:"31",n:"Haute-Garonne",lat:43.4,lon:1.4},
