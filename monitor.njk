---
pagination:
  data: langs
  size: 1
  alias: lang
langs:
  - fr
  - en
permalink: "/{{ lang }}/monitor/"
layout: false
---
<!DOCTYPE html>
<html lang="{{ lang }}">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
{% if lang == "fr" %}
<title>Moniteur de risque coup de chaleur d'effort — Kollder</title>
<meta name="description" content="Outil de surveillance du risque de coup de chaleur d'effort (EHS) par département. WBGT en temps réel, protocoles d'urgence et alertes personnalisées selon votre profil.">
{% else %}
<title>Exertional Heat Stroke Risk Monitor — Kollder</title>
<meta name="description" content="Real-time exertional heat stroke (EHS) risk monitoring by department. Live WBGT, emergency protocols and personalised alerts for your profile.">
{% endif %}
<link rel="icon" href="/favicon.ico">
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Sans:wght@400;500&display=swap">
<style>
:root {
  --black: #0f0f0d;
  --ink: #1a1a17;
  --white: #faf9f7;
  --cream: #f0ece4;
  --risk-low-bg: #EAF3DE; --risk-low-text: #27500A; --risk-low-border: #97C459;
  --risk-mod-bg: #FAEEDA; --risk-mod-text: #633806; --risk-mod-border: #EF9F27;
  --risk-hi-bg:  #FAECE7; --risk-hi-text:  #712B13; --risk-hi-border:  #D85A30;
  --risk-cr-bg:  #FCEBEB; --risk-cr-text:  #791F1F; --risk-cr-border:  #E24B4A;
  --dot-low: #639922; --dot-mod: #EF9F27; --dot-hi: #D85A30; --dot-cr: #E24B4A;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: 'DM Sans', sans-serif; background: var(--white); color: var(--ink); min-height: 100vh; }

/* NAV */
.nav { display: flex; align-items: center; justify-content: space-between; padding: 0 2rem; height: 64px; border-bottom: 1px solid #e8e4dc; background: var(--white); }
.nav-logo img { height: 48px; display: block; mix-blend-mode: multiply; }
.nav-back { font-size: 13px; color: #888; text-decoration: none; display: flex; align-items: center; gap: 6px; }
.nav-back:hover { color: var(--ink); }
.nav-lang { display: flex; gap: 8px; }
.nav-lang a { font-size: 12px; padding: 4px 10px; border: 1px solid #e0dcd4; border-radius: 4px; text-decoration: none; color: #888; }
.nav-lang a.active { border-color: var(--ink); color: var(--ink); font-weight: 500; }

/* HERO */
.hero { background: var(--black); color: var(--white); padding: 3rem 2rem 2.5rem; text-align: center; }
.hero-eyebrow { font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: #888; margin-bottom: 0.75rem; }
.hero-title { font-family: 'DM Serif Display', serif; font-size: clamp(26px, 4vw, 38px); line-height: 1.15; margin-bottom: 1rem; }
.hero-title em { font-style: normal; color: #E24B4A; }
.hero-sub { font-size: 14px; color: #aaa; max-width: 540px; margin: 0 auto; line-height: 1.7; }
.hero-wbgt-pill { display: inline-flex; align-items: center; gap: 8px; margin-top: 1.5rem; border: 1px solid #333; border-radius: 20px; padding: 6px 16px; font-size: 12px; color: #bbb; }
.hero-wbgt-pill span { color: var(--white); font-weight: 500; }

/* MAIN LAYOUT */
.page { max-width: 860px; margin: 0 auto; padding: 2rem 1.5rem 4rem; }

/* SELECTOR ROW */
.selector-row { display: flex; gap: 12px; align-items: flex-end; margin-bottom: 1.5rem; flex-wrap: wrap; }
.selector-row label { font-size: 12px; color: #888; margin-bottom: 4px; display: block; }
.selector-row select { font-family: 'DM Sans', sans-serif; font-size: 14px; padding: 10px 14px; border: 1px solid #d8d4cc; border-radius: 6px; background: var(--white); color: var(--ink); min-width: 220px; cursor: pointer; }
.selector-row select:focus { outline: 2px solid var(--ink); }
.btn-refresh { font-family: 'DM Sans', sans-serif; font-size: 13px; padding: 10px 18px; border: 1px solid #d8d4cc; border-radius: 6px; background: var(--white); color: var(--ink); cursor: pointer; display: flex; align-items: center; gap: 6px; }
.btn-refresh:hover { background: var(--cream); }

/* LOADING */
#km-loading { padding: 3rem; text-align: center; font-size: 14px; color: #888; display: none; }

/* STATS GRID */
.stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 10px; margin-bottom: 1.25rem; }
.stat-card { background: var(--cream); border-radius: 8px; padding: 14px 16px; }
.stat-label { font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: #888; margin-bottom: 6px; }
.stat-value { font-size: 26px; font-weight: 500; color: var(--ink); line-height: 1; }
.stat-unit { font-size: 13px; color: #888; margin-left: 2px; }
.stat-note { font-size: 11px; color: #aaa; margin-top: 4px; }

/* RISK BANNER */
.risk-banner { border-radius: 10px; padding: 18px 20px; margin-bottom: 1.5rem; border-left: 4px solid; display: flex; gap: 16px; align-items: flex-start; }
.risk-banner-icon { font-size: 28px; line-height: 1; flex-shrink: 0; }
.risk-banner-level { font-size: 17px; font-weight: 500; margin-bottom: 4px; }
.risk-banner-desc { font-size: 13px; line-height: 1.6; opacity: 0.85; }
.risk-banner-protocol { margin-top: 8px; font-size: 12px; font-weight: 500; letter-spacing: 0.04em; padding: 4px 10px; border-radius: 4px; display: inline-block; }

/* TABS */
.tabs { display: flex; border-bottom: 1px solid #e8e4dc; margin-bottom: 1.5rem; gap: 0; overflow-x: auto; }
.tab { font-family: 'DM Sans', sans-serif; font-size: 13px; padding: 10px 18px; border: none; background: none; color: #888; cursor: pointer; border-bottom: 2px solid transparent; margin-bottom: -1px; white-space: nowrap; }
.tab.active { color: var(--ink); border-bottom-color: var(--ink); font-weight: 500; }
.panel { display: none; }
.panel.active { display: block; }

/* FORECAST */
.forecast-grid { display: grid; grid-template-columns: repeat(7, minmax(0, 1fr)); gap: 8px; }
.fc-card { background: var(--cream); border-radius: 8px; padding: 10px 6px; text-align: center; }
.fc-day { font-size: 10px; color: #888; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 6px; }
.fc-temp { font-size: 16px; font-weight: 500; color: var(--ink); }
.fc-hum { font-size: 10px; color: #aaa; margin-top: 2px; }
.fc-wbgt { font-size: 11px; font-weight: 500; margin-top: 5px; }
.fc-dot { width: 8px; height: 8px; border-radius: 50%; margin: 5px auto 0; }

/* RECOMMENDATIONS */
.recos { display: flex; flex-direction: column; gap: 10px; }
.reco-card { background: var(--cream); border-radius: 8px; padding: 14px 16px; display: flex; gap: 12px; }
.reco-icon { font-size: 20px; flex-shrink: 0; }
.reco-title { font-size: 13px; font-weight: 500; color: var(--ink); margin-bottom: 3px; }
.reco-body { font-size: 12px; color: #666; line-height: 1.6; }
.reco-card.reco-kollder { border-left: 3px solid var(--ink); background: #f5f2ec; }
.reco-kollder .reco-title::after { content: " — Kollder"; font-weight: 400; color: #888; }

/* ALERT SECTION */
.alert-section { margin-top: 2rem; border: 1px solid #e8e4dc; border-radius: 12px; overflow: hidden; }
.alert-header { background: var(--black); color: var(--white); padding: 16px 20px; display: flex; align-items: center; gap: 10px; }
.alert-header-title { font-size: 15px; font-weight: 500; }
.alert-header-sub { font-size: 12px; color: #aaa; margin-top: 2px; }
.alert-body { padding: 20px; }
.alert-form { display: flex; flex-direction: column; gap: 14px; }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
.form-group { display: flex; flex-direction: column; gap: 5px; }
.form-group label { font-size: 12px; color: #888; font-weight: 500; letter-spacing: 0.04em; text-transform: uppercase; }
.form-group input, .form-group select { font-family: 'DM Sans', sans-serif; font-size: 14px; padding: 10px 12px; border: 1px solid #d8d4cc; border-radius: 6px; background: var(--white); color: var(--ink); }
.form-group input:focus, .form-group select:focus { outline: 2px solid var(--ink); }
.threshold-pills { display: flex; gap: 8px; flex-wrap: wrap; }
.pill { font-family: 'DM Sans', sans-serif; font-size: 12px; padding: 6px 14px; border-radius: 20px; border: 1px solid #d8d4cc; background: var(--white); color: #888; cursor: pointer; }
.pill.active { border-color: var(--ink); background: var(--ink); color: var(--white); }
.pill.pill-mod.active { border-color: #EF9F27; background: #FAEEDA; color: #633806; }
.pill.pill-hi.active  { border-color: #D85A30; background: #FAECE7; color: #712B13; }
.pill.pill-cr.active  { border-color: #E24B4A; background: #FCEBEB; color: #791F1F; }
.btn-subscribe { font-family: 'DM Serif Display', serif; font-size: 15px; padding: 12px 24px; background: var(--black); color: var(--white); border: none; border-radius: 6px; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px; }
.btn-subscribe:hover { background: #2a2a27; }
.alert-success { background: #EAF3DE; border-radius: 8px; padding: 16px; text-align: center; font-size: 14px; color: #27500A; display: none; }
.alert-disclaimer { font-size: 11px; color: #aaa; line-height: 1.6; margin-top: 8px; }

/* FOOTER */
.km-footer { margin-top: 2rem; padding-top: 1rem; border-top: 1px solid #e8e4dc; display: flex; justify-content: space-between; font-size: 11px; color: #aaa; flex-wrap: wrap; gap: 4px; }

/* SITE FOOTER */
.site-footer { background: var(--black); color: #666; padding: 2rem; text-align: center; font-size: 12px; }
.site-footer a { color: #888; text-decoration: none; }
.site-footer a:hover { color: var(--white); }

@media (max-width: 600px) {
  .form-row { grid-template-columns: 1fr; }
  .forecast-grid { grid-template-columns: repeat(4, minmax(0, 1fr)); }
  .forecast-grid .fc-card:nth-child(n+5) { display: none; }
  .hero { padding: 2rem 1rem 1.5rem; }
}
</style>
</head>
<body>

<nav class="nav">
  <a href="/{{ lang }}/" class="nav-logo">
    <img src="/images/logo.png" alt="Kollder" onerror="this.style.display='none';this.nextElementSibling.style.display='block'">
    <span style="display:none;font-family:'DM Serif Display',serif;font-size:20px;color:var(--ink)">Kollder</span>
  </a>
  <div class="nav-lang">
    <a href="/fr/monitor/" class="{{ 'active' if lang == 'fr' }}">FR</a>
    <a href="/en/monitor/" class="{{ 'active' if lang == 'en' }}">EN</a>
  </div>
</nav>

<div class="hero">
  <div class="hero-eyebrow">Kollder — Outil médical d'aide à la décision</div>
  {% if lang == "fr" %}
  <h1 class="hero-title">Risque de <em>coup de chaleur d'effort</em><br>par département</h1>
  <p class="hero-sub">Le WBGT (Wet Bulb Globe Temperature) est l'indice de référence ACSM pour évaluer le risque d'hyperthermie d'effort. Au-delà de 28°C, chaque minute sans refroidissement actif compte.</p>
  {% else %}
  <h1 class="hero-title"><em>Exertional heat stroke</em> risk<br>by department</h1>
  <p class="hero-sub">WBGT (Wet Bulb Globe Temperature) is the ACSM reference index for exertional heat stroke risk. Above 28°C, every minute without active cooling counts.</p>
  {% endif %}
  <div class="hero-wbgt-pill">
    <span id="hero-wbgt">--°C WBGT</span>
    <span id="hero-dept-name" style="color:#888">--</span>
  </div>
</div>

<main class="page">

  <div class="selector-row">
    <div>
      <label for="km-select">{% if lang == "fr" %}Département{% else %}Department{% endif %}</label>
      <select id="km-select" aria-label="{% if lang == 'fr' %}Sélectionner un département{% else %}Select a department{% endif %}"></select>
    </div>
    <button class="btn-refresh" id="km-refresh" aria-label="{% if lang == 'fr' %}Actualiser{% else %}Refresh{% endif %}">
      ↻ {% if lang == "fr" %}Actualiser{% else %}Refresh{% endif %}
    </button>
  </div>

  <div id="km-loading">{% if lang == "fr" %}Chargement des données météo...{% else %}Loading weather data...{% endif %}</div>

  <div id="km-main">
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-label">{% if lang == "fr" %}Température{% else %}Temperature{% endif %}</div>
        <div class="stat-value" id="v-temp">--<span class="stat-unit">°C</span></div>
        <div class="stat-note">{% if lang == "fr" %}Air ambiant{% else %}Ambient air{% endif %}</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">{% if lang == "fr" %}Humidité{% else %}Humidity{% endif %}</div>
        <div class="stat-value" id="v-hum">--<span class="stat-unit">%</span></div>
        <div class="stat-note">{% if lang == "fr" %}Relative{% else %}Relative{% endif %}</div>
      </div>
      <div class="stat-card" style="border: 2px solid #e8e4dc; position:relative;">
        <div style="position:absolute;top:8px;right:10px;font-size:9px;letter-spacing:0.08em;text-transform:uppercase;color:#E24B4A;font-weight:500">ACSM REF.</div>
        <div class="stat-label">WBGT</div>
        <div class="stat-value" id="v-wbgt" style="font-family:'DM Serif Display',serif">--<span class="stat-unit">°C</span></div>
        <div class="stat-note">{% if lang == "fr" %}Indice thermique EHS{% else %}EHS heat index{% endif %}</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">{% if lang == "fr" %}Vent{% else %}Wind{% endif %}</div>
        <div class="stat-value" id="v-wind">--<span class="stat-unit">km/h</span></div>
        <div class="stat-note">{% if lang == "fr" %}Rafales{% else %}Gusts{% endif %}</div>
      </div>
    </div>

    <div class="risk-banner" id="km-banner">
      <div class="risk-banner-icon" id="b-icon">—</div>
      <div style="flex:1">
        <div class="risk-banner-level" id="b-level">—</div>
        <div class="risk-banner-desc" id="b-desc">—</div>
        <div class="risk-banner-protocol" id="b-protocol" style="display:none"></div>
      </div>
    </div>

    <div class="tabs">
      <button class="tab active" data-tab="forecast">{% if lang == "fr" %}Prévision 7 jours{% else %}7-day forecast{% endif %}</button>
      <button class="tab" data-tab="recos">{% if lang == "fr" %}Protocoles d'urgence{% else %}Emergency protocols{% endif %}</button>
    </div>

    <div id="tab-forecast" class="panel active">
      <div class="forecast-grid" id="km-fc"></div>
    </div>

    <div id="tab-recos" class="panel">
      <div class="recos" id="km-recos"></div>
    </div>

    <!-- ALERT SECTION — always shown after first search -->
    <div class="alert-section" id="km-alert-section" style="display:none">
      <div class="alert-header">
        <div>
          <div class="alert-header-title" id="alert-header-title">—</div>
          <div class="alert-header-sub" id="alert-header-sub">—</div>
        </div>
      </div>
      <div class="alert-body">
        <form class="alert-form" id="km-alert-form" action="https://formspree.io/f/mykovqeg" method="POST">
          <input type="hidden" name="_subject" id="form-subject" value="">
          <input type="hidden" name="department" id="form-dept" value="">
          <input type="hidden" name="wbgt" id="form-wbgt" value="">
          <input type="hidden" name="risk_level" id="form-risk" value="">
          <input type="hidden" name="threshold" id="form-threshold" value="modere">
          <input type="hidden" name="lang" value="{{ lang }}">

          <div class="form-row">
            <div class="form-group">
              <label for="form-email">{% if lang == "fr" %}Email professionnel{% else %}Professional email{% endif %}</label>
              <input type="email" id="form-email" name="email" placeholder="prenom@organisation.fr" required>
            </div>
            <div class="form-group">
              <label for="form-profile">{% if lang == "fr" %}Votre profil{% else %}Your profile{% endif %}</label>
              <select id="form-profile" name="profile">
                {% if lang == "fr" %}
                <option value="organisateur">Organisateur d'événement sportif</option>
                <option value="sdis">SDIS / Sapeurs-pompiers</option>
                <option value="ehs">Responsable EHS / HSE industrie</option>
                <option value="medecin">Médecin urgentiste / SMUR</option>
                <option value="militaire">Médecin militaire / SSSM</option>
                <option value="autre">Autre</option>
                {% else %}
                <option value="organisateur">Sports event organiser</option>
                <option value="sdis">Fire & Rescue / EMS</option>
                <option value="ehs">EHS / HSE manager (industry)</option>
                <option value="medecin">Emergency physician / EMS</option>
                <option value="militaire">Military medical officer</option>
                <option value="autre">Other</option>
                {% endif %}
              </select>
            </div>
          </div>

          <div class="form-group">
            <label>{% if lang == "fr" %}Seuil d'alerte souhaité{% else %}Alert threshold{% endif %}</label>
            <div class="threshold-pills">
              <button type="button" class="pill pill-mod active" data-val="modere" onclick="setThreshold(this,'modere')">
                {% if lang == "fr" %}Dès risque Modéré (WBGT > 28°C){% else %}From Moderate risk (WBGT > 28°C){% endif %}
              </button>
              <button type="button" class="pill pill-hi" data-val="eleve" onclick="setThreshold(this,'eleve')">
                {% if lang == "fr" %}Dès risque Élevé (WBGT > 31°C){% else %}From High risk (WBGT > 31°C){% endif %}
              </button>
              <button type="button" class="pill pill-cr" data-val="critique" onclick="setThreshold(this,'critique')">
                {% if lang == "fr" %}Risque Critique uniquement (WBGT > 35°C){% else %}Critical risk only (WBGT > 35°C){% endif %}
              </button>
            </div>
          </div>

          <div style="display:flex;gap:12px;align-items:center;flex-wrap:wrap">
            <button type="submit" class="btn-subscribe">
              {% if lang == "fr" %}Activer les alertes EHS{% else %}Activate EHS alerts{% endif %} →
            </button>
            <div class="alert-disclaimer">
              {% if lang == "fr" %}Email unique. Pas de newsletter. Uniquement les alertes EHS pour le département sélectionné.
              {% else %}Single email. No newsletter. Only EHS alerts for the selected department.{% endif %}
            </div>
          </div>
        </form>
        <div class="alert-success" id="alert-success">
          {% if lang == "fr" %}✓ Alertes EHS activées. Vous serez notifié dès que le seuil choisi est atteint pour ce département.
          {% else %}✓ EHS alerts activated. You will be notified when the selected threshold is reached for this department.{% endif %}
        </div>
      </div>
    </div>

    <div class="km-footer">
      <span>Open-Meteo · WBGT méthode Liljegren approx. · Seuils ACSM Expert Consensus 2023</span>
      <span id="km-updated">—</span>
    </div>
  </div>

</main>

<footer class="site-footer">
  <a href="/{{ lang }}/">kollder.com</a> &nbsp;·&nbsp;
  <a href="/{{ lang }}/#contact">{% if lang == "fr" %}Demander un devis{% else %}Request a quote{% endif %}</a>
  &nbsp;·&nbsp; {% if lang == "fr" %}Outil clinique de référence pour la prévention du coup de chaleur d'effort{% else %}Clinical reference tool for exertional heat stroke prevention{% endif %}
</footer>

<script>
var LANG = "{{ lang }}";

var DEPTS = [
  {c:"01",n:"Ain",lat:46.2,lon:5.2},{c:"02",n:"Aisne",lat:49.5,lon:3.6},
  {c:"03",n:"Allier",lat:46.3,lon:3.4},{c:"04",n:"Alpes-de-Haute-Provence",lat:44.1,lon:6.2},
  {c:"05",n:"Hautes-Alpes",lat:44.7,lon:6.3},{c:"06",n:"Alpes-Maritimes",lat:43.9,lon:7.2},
  {c:"07",n:"Ardèche",lat:44.7,lon:4.4},{c:"08",n:"Ardennes",lat:49.7,lon:4.7},
