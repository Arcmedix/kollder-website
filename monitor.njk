  {c:"36",n:"Indre",lat:46.8,lon:1.6},{c:"37",n:"Indre-et-Loire",lat:47.2,lon:0.7},
  {c:"38",n:"Isère",lat:45.3,lon:5.6},{c:"39",n:"Jura",lat:46.7,lon:5.7},
  {c:"40",n:"Landes",lat:44.0,lon:-0.8},{c:"41",n:"Loir-et-Cher",lat:47.6,lon:1.3},
  {c:"42",n:"Loire",lat:45.6,lon:4.2},{c:"43",n:"Haute-Loire",lat:45.1,lon:3.9},
