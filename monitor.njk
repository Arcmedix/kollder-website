function calcWBGT(t,h){var tw=t*Math.atan(0.151977*Math.sqrt(h+8.313659))+Math.atan(t+h)-Math.atan(h-1.676331)+0.00391838*Math.pow(h,1.5)*Math.atan(0.023101*h)-4.686035;return Math.round((0.7*tw+0.3*t)*10)/10;}
function getRisk(w){if(w>=35)return 3;if(w>=31)return 2;if(w>=28)return 1;return 0;}
var currentCode="13";
function setThreshold(el,val){document.querySelectorAll('.pill').forEach(function(p){p.classList.remove('active');});el.classList.add('active');document.getElementById('form-threshold').value=val;}
var sel=document.getElementById('km-select');
DEPTS.forEach(function(d){var o=document.createElement('option');o.value=d.c;o.textContent=d.c+" — "+d.n;sel.appendChild(o);});
sel.value="13";
async function loadDept(code){
  var d=DEPTS.find(function(x){return x.c===code;});if(!d)return;
  currentCode=code;
  document.getElementById('km-loading').style.display='block';
  document.getElementById('km-main').style.display='none';
  try{
    var url="https://api.open-meteo.com/v1/forecast?latitude="+d.lat+"&longitude="+d.lon+"&current=temperature_2m,relative_humidity_2m,wind_speed_10m&daily=temperature_2m_max,relative_humidity_2m_mean,wind_speed_10m_max&timezone=Europe/Paris&forecast_days=7";
    var res=await fetch(url);var json=await res.json();
    var temp=Math.round(json.current.temperature_2m*10)/10;
    var hum=Math.round(json.current.relative_humidity_2m);
    var wind=Math.round(json.current.wind_speed_10m);
    var wbgt=calcWBGT(temp,hum);var ri=getRisk(wbgt);
    var RISK=LANG==='fr'?RISK_FR:RISK_EN;var r=RISK[ri];
    document.getElementById('v-temp').innerHTML=temp+'<span class="stat-unit">°C</span>';
    document.getElementById('v-hum').innerHTML=hum+'<span class="stat-unit">%</span>';
    document.getElementById('v-wbgt').innerHTML=wbgt+'<span class="stat-unit">°C</span>';
    document.getElementById('v-wind').innerHTML=wind+'<span class="stat-unit">km/h</span>';
    document.getElementById('hero-wbgt').textContent=wbgt+"°C WBGT";
    document.getElementById('hero-dept-name').textContent=d.n;
    var banner=document.getElementById('km-banner');
    banner.style.background=r.bg;banner.style.borderLeftColor=r.border;
    document.getElementById('b-level').textContent=r.level;document.getElementById('b-level').style.color=r.color;
    document.getElementById('b-desc').textContent=r.desc;document.getElementById('b-desc').style.color=r.color;
    var proto=document.getElementById('b-protocol');
    if(r.protocol){proto.textContent=r.protocol;proto.style.display='inline-block';proto.style.background=r.border;proto.style.color=r.color;}else{proto.style.display='none';}
    var DAYS=LANG==='fr'?DAYS_FR:DAYS_EN;
    var fc=document.getElementById('km-fc');fc.innerHTML='';
    var now=new Date();
    for(var i=0;i<7;i++){
      var ft=Math.round(json.daily.temperature_2m_max[i]);
      var fh=Math.round(json.daily.relative_humidity_2m_mean[i]);
      var fw=calcWBGT(ft,fh);var fri=getRisk(fw);
      var d2=new Date(now);d2.setDate(now.getDate()+i);
      var label=i===0?(LANG==='fr'?'Auj.':'Today'):DAYS[d2.getDay()];
      var el=document.createElement('div');el.className='fc-card';
      el.innerHTML='<div class="fc-day">'+label+'</div><div class="fc-temp">'+ft+'°</div><div class="fc-hum">'+fh+'% HR</div><div class="fc-wbgt" style="color:'+RISK[fri].dot+'">WBGT '+fw+'°</div><div class="fc-dot" style="background:'+RISK[fri].dot+'"></div>';
      fc.appendChild(el);
    }
    var RECOS=LANG==='fr'?RECOS_FR:RECOS_EN;
    var recos=document.getElementById('km-recos');recos.innerHTML='';
    RECOS[ri].forEach(function(rc){var el=document.createElement('div');el.className='reco-card'+(rc.kollder?' reco-kollder':'');el.innerHTML='<div class="reco-icon">'+rc.icon+'</div><div><div class="reco-title">'+rc.title+'</div><div class="reco-body">'+rc.body+'</div></div>';recos.appendChild(el);});
    var ALERT=LANG==='fr'?ALERT_FR:ALERT_EN;
    document.getElementById('alert-header-title').textContent=ALERT[ri].title;
    document.getElementById('alert-header-sub').textContent=ALERT[ri].sub;
    document.getElementById('form-dept').value=d.c+" — "+d.n;
    document.getElementById('form-wbgt').value=wbgt;
    document.getElementById('form-risk').value=r.level;
    document.getElementById('form-subject').value="[Kollder EHS Alert] "+d.n+" — WBGT "+wbgt+"°C — "+r.level;
    document.getElementById('km-alert-section').style.display='block';
    var t=new Date();
    document.getElementById('km-updated').textContent=d.n+" · "+t.toLocaleTimeString(LANG==='fr'?'fr-FR':'en-GB',{hour:'2-digit',minute:'2-digit'});
    document.getElementById('km-loading').style.display='none';
    document.getElementById('km-main').style.display='block';
  }catch(e){
    document.getElementById('km-loading').textContent=LANG==='fr'?"Erreur de chargement. Vérifiez la connexion.":"Loading error. Please check your connection.";
  }
}
sel.addEventListener('change',function(e){if(e.target.value)loadDept(e.target.value);});
document.getElementById('km-refresh').addEventListener('click',function(){loadDept(currentCode);});
document.querySelectorAll('.tab').forEach(function(btn){btn.addEventListener('click',function(){document.querySelectorAll('.tab').forEach(function(b){b.classList.remove('active');});document.querySelectorAll('.panel').forEach(function(p){p.classList.remove('active');});btn.classList.add('active');document.getElementById('tab-'+btn.dataset.tab).classList.add('active');});});
document.getElementById('km-alert-form').addEventListener('submit',function(e){e.preventDefault();var data=new FormData(this);fetch(this.action,{method:'POST',body:data,headers:{'Accept':'application/json'}}).then(function(r){if(r.ok){document.getElementById('km-alert-form').style.display='none';document.getElementById('alert-success').style.display='block';}});});
(async function autoDetect(){
  try{
    var geo=await fetch('https://ipapi.co/json/');
    var gd=await geo.json();
    var code='13';
    if(gd.country_code==='FR' && gd.region_code){
      // ipapi.co returns region_code as dept number string for France ("01".."95","2A","2B","971"..)
      var rc=String(gd.region_code);
      var found=DEPTS.find(function(x){return x.c===rc;});
      if(found) code=found.c;
      else code=DEPTS[Math.floor(Math.random()*DEPTS.length)].c;
    } else {
      code=DEPTS[Math.floor(Math.random()*DEPTS.length)].c;
    }
    sel.value=code;
    loadDept(code);
  }catch(e){
    var fallbackCode=DEPTS[Math.floor(Math.random()*DEPTS.length)].c;
    sel.value=fallbackCode;
    loadDept(fallbackCode);
  }
})();
</script>
<script>
document.addEventListener('DOMContentLoaded', function() {
  var btn = document.getElementById('hamBtn');
  var overlay = document.getElementById('navOverlay');
  if (!btn || !overlay) return;
  btn.addEventListener('click', function() {
    var isOpen = overlay.classList.toggle('open');
    btn.classList.toggle('open', isOpen);
    document.body.style.overflow = isOpen ? 'hidden' : '';
  });
  overlay.querySelectorAll('a').forEach(function(a) {
    a.addEventListener('click', function() {
      overlay.classList.remove('open');
      btn.classList.remove('open');
      document.body.style.overflow = '';
    });
  });
});
</script>
</body>
</html>
