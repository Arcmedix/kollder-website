---
layout: null
permalink: /sitemap.xml
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:xhtml="http://www.w3.org/1999/xhtml">

  <!-- Homepage -->
  <url>
    <loc>https://kollder.com/</loc>
    <changefreq>weekly</changefreq>
    <priority>1.0</priority>
  </url>

  <!-- Blog index -->
  <url>
    <loc>https://kollder.com/blog/</loc>
    <changefreq>daily</changefreq>
    <priority>0.9</priority>
  </url>

  <!-- Category pages FR -->
  {% for cat in categories %}
  <url>
    <loc>https://kollder.com/blog/fr/categorie/{{ cat.slug_fr }}/</loc>
    <xhtml:link rel="alternate" hreflang="fr" href="https://kollder.com/blog/fr/categorie/{{ cat.slug_fr }}/"/>
    <xhtml:link rel="alternate" hreflang="en" href="https://kollder.com/blog/en/category/{{ cat.slug_en }}/"/>
    <changefreq>weekly</changefreq>
    <priority>0.8</priority>
  </url>
  {% endfor %}

  <!-- Category pages EN -->
  {% for cat in categories %}
  <url>
    <loc>https://kollder.com/blog/en/category/{{ cat.slug_en }}/</loc>
    <xhtml:link rel="alternate" hreflang="en" href="https://kollder.com/blog/en/category/{{ cat.slug_en }}/"/>
    <xhtml:link rel="alternate" hreflang="fr" href="https://kollder.com/blog/fr/categorie/{{ cat.slug_fr }}/"/>
    <changefreq>weekly</changefreq>
    <priority>0.8</priority>
  </url>
  {% endfor %}

  <!-- FR blog articles -->
  {% for post in collections.blog_fr %}
  <url>
    <loc>https://kollder.com{{ post.url }}</loc>
    <lastmod>{{ post.date | dateFormat }}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.7</priority>
  </url>
  {% endfor %}

  <!-- EN blog articles -->
  {% for post in collections.blog_en %}
  <url>
    <loc>https://kollder.com{{ post.url }}</loc>
    <lastmod>{{ post.date | dateFormatEN }}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.7</priority>
  </url>
  {% endfor %}

</urlset>
