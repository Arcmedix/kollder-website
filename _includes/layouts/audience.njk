<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root {
  --black: #0f0f0d; --ink: #1a1a17; --white: #faf9f7;
  --cream: #f0ece4; --beige: #e8e0d4; --sand: #c8bfb0;
  --muted: #8a8278; --border: rgba(26,26,23,0.1);
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
body { background: var(--white); color: var(--ink); font-family: 'DM Sans', sans-serif; font-weight: 300; line-height: 1.7; }

/* NAV */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  display: flex; justify-content: space-between; align-items: center;
  padding: 14px 56px; background: rgba(255,255,255,0.95);
  backdrop-filter: blur(20px); border-bottom: 1px solid rgba(0,0,0,0.08);
}
.nav-brand img { height: 52px; width: auto; display: block; }
.nav-right { display: flex; align-items: center; gap: 28px; }
.nav-link {
  font-size: 13px; font-weight: 500; color: var(--muted);
  text-decoration: none; letter-spacing: 0.06em;
  display: flex; align-items: center; gap: 8px; transition: color .2s;
}
.nav-link:hover { color: var(--ink); }
.nav-link-active { color: var(--ink); }
.nav-devis {
  font-family: 'DM Sans', sans-serif; font-size: 12px; font-weight: 500;
  letter-spacing: 0.1em; text-transform: uppercase; text-decoration: none;
  padding: 9px 20px; background: var(--black); color: var(--white);
  transition: background .2s;
}
.nav-devis:hover { background: #333; }
.nav-badge {
  display: inline-flex; align-items: center; justify-content: center;
  background: var(--sand); color: var(--ink); font-size: 10px; font-weight: 500;
  padding: 1px 6px; border-radius: 10px; margin-left: 4px;
}
.lang-toggle { display: flex; border: 1px solid var(--border); }
.lang-btn {
  background: none; border: none; font-family: 'DM Sans', sans-serif;
  font-size: 12px; font-weight: 500; letter-spacing: 0.1em;
  padding: 6px 12px; cursor: pointer; color: var(--muted); transition: all .2s;
  text-decoration: none; display: inline-block;
}
.lang-btn.active { background: var(--black); color: var(--white); }

/* Hamburger */
.ham-btn {
  display: none; flex-direction: column; justify-content: center;
  gap: 5px; background: none; border: none; cursor: pointer;
  padding: 4px; z-index: 200;
}
.ham-btn span {
  display: block; width: 22px; height: 2px;
  background: var(--ink); transition: all .25s;
}
.ham-btn.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.ham-btn.open span:nth-child(2) { opacity: 0; }
.ham-btn.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

/* Mobile overlay */
.nav-overlay {
  display: none; position: fixed; inset: 0; z-index: 150;
  background: var(--white); flex-direction: column;
  padding: 90px 32px 40px;
}
.nav-overlay.open { display: flex; }
.nav-overlay-links {
  display: flex; flex-direction: column; gap: 8px; flex: 1;
}
.nav-overlay-link {
  font-size: 22px; font-weight: 400; color: var(--ink);
  text-decoration: none; padding: 14px 0;
  border-bottom: 1px solid var(--border);
  display: flex; align-items: center; justify-content: space-between;
  font-family: 'DM Serif Display', serif;
}
.nav-overlay-link:last-child { border-bottom: none; }
.nav-overlay-badge {
  display: inline-block; font-size: 10px; font-weight: 500;
  letter-spacing: 0.04em; font-family: 'DM Sans', sans-serif;
  background: var(--beige, #e8e4dc); color: var(--muted, #888);
  padding: 2px 8px; border-radius: 20px; margin-left: 8px;
  vertical-align: middle; line-height: 1.6;
}
.nav-overlay-cta {
  display: inline-flex; align-items: center; gap: 10px; margin-top: 32px;
  background: var(--black); color: var(--white); text-decoration: none;
  font-size: 13px; font-weight: 500; letter-spacing: 0.1em;
  text-transform: uppercase; padding: 16px 28px; align-self: flex-start;
}
.nav-overlay-lang {
  display: flex; gap: 0; border: 1px solid var(--border);
  margin-top: 24px; align-self: flex-start;
}
.nav-overlay-lang a {
  font-size: 12px; font-weight: 500; letter-spacing: 0.1em;
  padding: 8px 16px; text-decoration: none; color: var(--muted);
}
.nav-overlay-lang a.active { background: var(--black); color: var(--white); }

/* HERO — deux colonnes façon home page */
.partner-hero {
  padding: 140px 56px 64px; background: var(--white); color: var(--ink);
}
.partner-hero-inner {
  max-width: 1240px; margin: 0 auto; width: 100%;
  display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 64px; align-items: center;
}
.partner-hero__label {
  font-size: 11px; font-weight: 500; letter-spacing: 0.2em;
  text-transform: uppercase; color: var(--muted); margin-bottom: 16px;
}
.partner-hero h1 {
  font-family: 'DM Serif Display', serif;
  font-size: clamp(32px, 4vw, 52px); font-weight: 400;
  line-height: 1.1; color: var(--black); margin-bottom: 20px;
}
.partner-hero__sub {
  font-size: 16px; color: var(--muted);
  max-width: 480px; line-height: 1.7; margin-bottom: 32px;
}
.partner-hero__dims { margin-top: 24px; display: flex; gap: 24px; flex-wrap: wrap; }
.partner-hero__dim {
  font-size: 12px; font-weight: 400; letter-spacing: 0.06em; color: var(--muted);
  display: flex; align-items: center; gap: 8px;
}
.partner-hero__dim::before {
  content: ''; width: 3px; height: 3px; border-radius: 50%;
  background: var(--sand); flex-shrink: 0;
}
.partner-hero__visual { position: relative; }
.partner-btn {
  display: inline-flex; align-items: center; gap: 10px;
  background: var(--white); color: var(--black);
  font-family: 'DM Sans', sans-serif; font-size: 13px; font-weight: 500;
  letter-spacing: 0.1em; text-transform: uppercase;
  padding: 15px 28px; text-decoration: none; transition: background .2s;
}
.partner-btn:hover { background: var(--cream); }
.partner-btn--solid { background: var(--black); color: var(--white); }
.partner-btn--solid:hover { background: var(--ink); }

@media (max-width: 900px) {
  .partner-hero-inner { grid-template-columns: 1fr; }
}

/* SECTIONS */
.partner-section { padding: 64px 56px; }
.partner-section--alt { background: var(--cream); }
.partner-section__inner { max-width: 1100px; margin: 0 auto; }
.partner-section--narrow { max-width: 720px; }
.partner-section h2 {
  font-family: 'DM Serif Display', serif;
  font-size: clamp(26px, 3vw, 40px); font-weight: 400;
  color: var(--black); margin-bottom: 16px; line-height: 1.15;
}
.partner-section__lead {
  font-size: 16px; color: var(--muted); max-width: 640px;
  line-height: 1.7; margin-bottom: 32px;
}
.partner-section__lead:last-child { margin-bottom: 0; }

/* NARRATIVE (texte + visuel côte à côte, sections 2 et 4) */
.partner-narrative {
  display: grid; grid-template-columns: 1.3fr 1fr; gap: 56px; align-items: start;
}
.partner-narrative__side { position: sticky; top: 100px; }

.partner-callout { background: var(--cream); border: 1px solid var(--border); padding: 8px 32px; }
.partner-section--alt .partner-callout { background: var(--white); }
.partner-callout__row { padding: 24px 0; border-bottom: 1px solid var(--border); }
.partner-callout__row:last-child { border-bottom: none; }
.partner-callout__figure {
  font-family: 'DM Serif Display', serif; font-size: 38px; color: var(--black);
  line-height: 1; margin-bottom: 8px;
}
.partner-callout__label { font-size: 13px; color: var(--muted); line-height: 1.5; }

.partner-x-list { background: var(--black); color: var(--white); padding: 32px; }
.partner-x-list__title {
  font-size: 11px; font-weight: 500; letter-spacing: 0.14em; text-transform: uppercase;
  color: var(--sand); margin-bottom: 20px;
}
.partner-x-list ul { list-style: none; padding: 0; }
.partner-x-list li {
  display: flex; align-items: flex-start; gap: 12px; padding: 14px 0;
  border-bottom: 1px solid rgba(255,255,255,0.08); font-size: 14px;
  color: rgba(250,249,247,0.75); line-height: 1.5;
}
.partner-x-list li:last-child { border-bottom: none; }
.partner-x-list li svg { flex-shrink: 0; margin-top: 3px; color: rgba(250,249,247,0.4); }

@media (max-width: 900px) {
  .partner-narrative { grid-template-columns: 1fr; }
  .partner-narrative__side { position: static; }
}

/* STATS (section 2) */
.partner-stats {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 2px; background: var(--border);
}
.partner-stat {
  background: var(--white); padding: 40px 36px;
}
.partner-section--alt .partner-stat { background: var(--cream); }
.partner-stat__figure {
  font-family: 'DM Serif Display', serif;
  font-size: 48px; color: var(--black); line-height: 1; margin-bottom: 6px;
}
.partner-stat__label {
  font-size: 11px; font-weight: 500; letter-spacing: 0.18em;
  text-transform: uppercase; color: var(--muted); margin-bottom: 18px;
}
.partner-stat p { font-size: 14px; color: var(--muted); line-height: 1.65; }

/* SEGMENTS (section 3) */
.partner-segments {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 24px; margin-top: 8px;
}
.partner-segment {
  border: 1px solid var(--border); background: var(--white); overflow: hidden;
}
.partner-section--alt .partner-segment { background: var(--cream); }
.partner-segment__img { width: 100%; aspect-ratio: 16/9; overflow: hidden; background: var(--beige); }
.partner-segment__img img { width: 100%; height: 100%; object-fit: cover; display: block; filter: grayscale(20%); transition: filter .3s; }
.partner-segment:hover .partner-segment__img img { filter: grayscale(0%); }
.partner-segment__img--placeholder {
  display: flex; align-items: center; justify-content: center;
  background: var(--ink);
}
.partner-segment__img--placeholder span {
  font-size: 11px; font-weight: 500; letter-spacing: 0.12em;
  text-transform: uppercase; color: rgba(250,249,247,0.35);
}
.partner-segment__body { padding: 24px; }
.partner-segment h3 {
  font-family: 'DM Sans', sans-serif; font-size: 15px; font-weight: 500;
  color: var(--black); margin-bottom: 8px;
}
.partner-segment p { font-size: 13px; color: var(--muted); line-height: 1.65; }

/* PRODUCT DARK SECTION (section 4) */
.partner-section--dark { background: var(--black); }
.partner-section--dark h2 { color: var(--white); }
.partner-section__h2--light { color: var(--white) !important; }
.partner-section__lead--light { color: rgba(250,249,247,0.5) !important; }
.partner-product-grid {
  display: grid; grid-template-columns: repeat(2, 1fr);
  gap: 2px; background: rgba(255,255,255,0.06); margin-top: 8px;
}
.partner-product-card { background: var(--black); overflow: hidden; }
.partner-product-card img { width: 100%; aspect-ratio: 4/3; object-fit: cover; display: block; filter: grayscale(30%) brightness(0.75); }
.partner-product-card__body { padding: 32px; }
.partner-product-card__icon { margin-bottom: 18px; color: var(--sand); }
.partner-product-card__kicker {
  display: block; font-size: 11px; font-weight: 500; letter-spacing: 0.14em;
  text-transform: uppercase; color: var(--sand); margin-bottom: 10px;
}
.partner-product-card h3 {
  font-family: 'DM Serif Display', serif; font-size: 18px; font-weight: 400;
  color: var(--white); line-height: 1.25; margin-bottom: 10px;
}
.partner-product-card p { font-size: 13px; color: rgba(250,249,247,0.45); line-height: 1.65; }

@media (max-width: 700px) {
  .partner-product-grid { grid-template-columns: 1fr; }
}

/* MERGED APPLY SECTION (section 6) */
.partner-apply {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 72px; align-items: start;
}
.partner-apply__left h2 { margin-bottom: 12px; }
.partner-apply__left > p { font-size: 15px; color: var(--muted); margin-bottom: 32px; line-height: 1.65; }
.partner-apply__criteria { margin-top: 8px; }
.partner-apply__criteria-title {
  font-size: 12px; font-weight: 500; letter-spacing: 0.1em;
  text-transform: uppercase; color: var(--muted); margin-bottom: 16px;
}
.partner-apply__criteria-note {
  margin-top: 20px; font-size: 13px; color: var(--muted); font-style: italic;
}

@media (max-width: 900px) {
  .partner-apply { grid-template-columns: 1fr; gap: 40px; }
  .partner-product-grid { grid-template-columns: 1fr; }
}

/* BENEFITS (section 5) */
.partner-benefits {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 24px; margin-top: 8px;
}
.partner-benefit {
  border-top: 2px solid var(--ink); padding-top: 20px;
}
.partner-benefit--wide { grid-column: 1 / -1; border-top-color: var(--sand); padding-top: 20px; }
.partner-benefit strong { display: block; font-size: 15px; font-weight: 500; color: var(--black); margin-bottom: 8px; }
.partner-benefit p { font-size: 14px; color: var(--muted); line-height: 1.65; }
.partner-note {
  margin-top: 40px; font-size: 13px; color: var(--muted);
  font-style: italic; border-top: 1px solid var(--border); padding-top: 20px;
}

/* CRITERIA (section 6) */
.partner-criteria {
  list-style: none; padding: 0; margin: 0 0 28px;
  display: flex; flex-direction: column; gap: 14px;
}
.partner-criteria li {
  font-size: 15px; color: var(--ink); padding-left: 20px; position: relative; line-height: 1.55;
}
.partner-criteria li::before {
  content: '—'; position: absolute; left: 0; color: var(--sand);
}
.partner-section--narrow > p {
  font-size: 15px; color: var(--muted); line-height: 1.65;
}

/* INLINE LINKS TO BLOG */
.partner-section a.inline-link,
.partner-section--alt a.inline-link,
.partner-section--dark a.inline-link {
  color: inherit; text-decoration: underline; text-underline-offset: 3px;
  text-decoration-color: var(--sand); transition: text-decoration-color .2s;
}
.partner-section a.inline-link:hover { text-decoration-color: var(--ink); }
.partner-section--dark a.inline-link { text-decoration-color: rgba(250,249,247,0.35); }
.partner-section--dark a.inline-link:hover { text-decoration-color: var(--white); }

/* SECONDARY / OUTLINE BUTTON */
.partner-btn--outline {
  background: transparent; color: var(--ink); border: 1px solid var(--ink);
}
.partner-btn--outline:hover { background: var(--ink); color: var(--white); }
.partner-section--dark .partner-btn--outline { color: var(--white); border-color: rgba(250,249,247,0.4); }
.partner-section--dark .partner-btn--outline:hover { background: var(--white); color: var(--black); }
.partner-cta-row { display: flex; flex-wrap: wrap; gap: 16px; margin-top: 8px; }

/* READING LIST / FURTHER READING */
.partner-reading {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 2px; background: var(--border); margin-top: 8px;
}
.partner-reading a {
  display: block; background: var(--white); padding: 24px; text-decoration: none;
  color: var(--ink); transition: background .2s;
}
.partner-reading a:hover { background: var(--cream); }
.partner-reading__kicker {
  display: block; font-size: 11px; font-weight: 500; letter-spacing: 0.1em;
  text-transform: uppercase; color: var(--muted); margin-bottom: 8px;
}
.partner-reading__title { font-size: 15px; font-weight: 500; line-height: 1.4; }

/* SOURCES STRIP */
.partner-sources {
  display: flex; align-items: center; flex-wrap: wrap; gap: 36px;
  padding-top: 28px; margin-top: 40px; border-top: 1px solid var(--border);
}
.partner-sources img { height: 26px; width: auto; opacity: 0.55; filter: grayscale(100%); }
.partner-sources__label {
  font-size: 11px; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted);
}

/* FAQ (native details/summary, no JS needed) */
.partner-faq { max-width: 820px; margin-top: 8px; }
.partner-faq details {
  border-bottom: 1px solid var(--border); padding: 22px 0;
}
.partner-faq summary {
  font-family: 'DM Sans', sans-serif; font-size: 16px; font-weight: 500;
  color: var(--black); cursor: pointer; list-style: none;
  display: flex; justify-content: space-between; align-items: center; gap: 16px;
}
.partner-faq summary::-webkit-details-marker { display: none; }
.partner-faq summary::after {
  content: '+'; font-size: 20px; font-weight: 300; color: var(--muted); flex-shrink: 0;
}
.partner-faq details[open] summary::after { content: '–'; }
.partner-faq p { font-size: 14px; color: var(--muted); line-height: 1.7; margin-top: 14px; max-width: 680px; }

/* SELECT FIELD (form) */
.partner-form__field select {
  border: 1px solid var(--border); background: var(--white);
  padding: 12px 14px; font-family: 'DM Sans', sans-serif;
  font-size: 15px; font-weight: 300; color: var(--ink); outline: none;
}
.partner-form__field select:focus { border-color: var(--ink); }

/* FORM (section 7) */
.partner-form { margin-top: 36px; display: flex; flex-direction: column; gap: 20px; }
.partner-form__row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
.partner-form__field { display: flex; flex-direction: column; gap: 6px; }
.partner-form__field label {
  font-size: 12px; font-weight: 500; letter-spacing: 0.1em;
  text-transform: uppercase; color: var(--muted);
}
.partner-form__field input,
.partner-form__field textarea {
  border: 1px solid var(--border); background: var(--white);
  padding: 12px 14px; font-family: 'DM Sans', sans-serif;
  font-size: 15px; font-weight: 300; color: var(--ink);
  outline: none; transition: border-color .2s; resize: vertical;
}
.partner-form__field input:focus,
.partner-form__field textarea:focus { border-color: var(--ink); }
.partner-form__field input::placeholder,
.partner-form__field textarea::placeholder { color: var(--muted); opacity: 0.55; }
.partner-form .partner-btn {
  background: var(--black); color: var(--white);
  align-self: flex-start; margin-top: 8px;
}
.partner-form .partner-btn:hover { background: var(--ink); }

/* PRODUCT SECTION — carousels repris de index.html */
.sec-label {
  font-size: 11px; font-weight: 500; letter-spacing: 0.2em;
  text-transform: uppercase; color: var(--muted); margin-bottom: 16px;
}
.sec-title {
  font-family: 'DM Serif Display', serif; font-size: clamp(28px, 3.5vw, 44px);
  font-weight: 400; line-height: 1.1; color: var(--black); margin-bottom: 8px; max-width: 600px;
}
.sec-title em { font-style: italic; color: var(--muted); }

.carousel-wrap { position: relative; overflow: hidden; aspect-ratio: 4/3; background: var(--cream); width: 100%; }
.carousel-track { display: flex; width: 400%; height: 100%; transition: transform 0.7s cubic-bezier(0.77,0,0.175,1); }
.carousel-slide { width: 25%; height: 100%; flex-shrink: 0; overflow: hidden; }
.carousel-slide img { width: 100%; height: 100%; object-fit: cover; display: block; }
.carousel-dots { position: absolute; bottom: 14px; left: 50%; transform: translateX(-50%); display: flex; gap: 8px; z-index: 10; }
.carousel-dot { width: 6px; height: 6px; border-radius: 50%; background: rgba(255,255,255,0.45); cursor: pointer; transition: background 0.2s; border: none; padding: 0; }
.carousel-dot.active { background: #fff; transform: scale(1.3); }
.thumb-strip { display: grid; grid-template-columns: repeat(4, 1fr); gap: 3px; margin-top: 3px; width: 100%; }
.thumb { aspect-ratio: 1; overflow: hidden; cursor: pointer; border: 2px solid transparent; transition: border-color .15s; background: var(--beige); }
.thumb.active { border-color: var(--black); }
.thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }

.field { background: var(--cream); padding: 64px 0; overflow: hidden; border-bottom: 1px solid var(--border); }
.field-inner { max-width: 1200px; margin: 0 auto; padding: 0 56px; }
.field-header { margin-bottom: 40px; }
.field-track-wrap { position: relative; overflow: hidden; cursor: grab; user-select: none; }
.field-track-wrap:active { cursor: grabbing; }
.field-track { display: flex; gap: 20px; transition: transform 0.45s cubic-bezier(0.25, 0.46, 0.45, 0.94); will-change: transform; }
.field-slide { flex: 0 0 auto; width: 560px; height: 420px; position: relative; overflow: hidden; background: var(--beige); border-radius: 4px; }
.field-slide img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.5s ease; }
.field-slide:hover img { transform: scale(1.02); }
.field-nav { display: flex; align-items: center; gap: 20px; margin-top: 28px; padding: 0 4px; }
.field-dots { display: flex; gap: 6px; flex: 1; }
.field-dot { width: 24px; height: 2px; background: var(--sand); border: none; cursor: pointer; padding: 0; transition: background 0.25s, width 0.25s; border-radius: 1px; }
.field-dot.active { background: var(--ink); width: 40px; }
.field-arrows { display: flex; gap: 8px; }
.field-arrow { width: 36px; height: 36px; border: 1px solid var(--border); background: var(--white); border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: background 0.2s, border-color 0.2s; color: var(--ink); }
.field-arrow:hover { background: var(--ink); border-color: var(--ink); color: var(--white); }
.field-arrow svg { pointer-events: none; }

@media (max-width: 768px) {
  .field-inner { padding: 0 24px; }
  .field-slide { width: 85vw; height: 320px; }
}

/* FOOTER — identique article.njk */
footer {
  background: #000; border-top: 1px solid rgba(255,255,255,0.08); padding: 40px 56px;
}
.footer-inner {
  max-width: 1240px; margin: 0 auto;
  display: flex; justify-content: space-between; align-items: center; gap: 24px; flex-wrap: wrap;
}
.footer-brand img { height: 52px; width: auto; display: block; filter: invert(1); }
.footer-note { font-size: 12px; color: rgba(250,249,247,0.25); letter-spacing: 0.04em; }

/* RESPONSIVE */
@media (max-width: 768px) {
  nav { padding: 14px 24px; }
  .nav-right { display: none; }
  .ham-btn { display: flex; }
  .partner-hero { padding: 110px 24px 48px; }
  .partner-section { padding: 48px 24px; }
  footer { padding: 32px 24px; }
  .partner-form__row { grid-template-columns: 1fr; }
  .partner-stats { grid-template-columns: 1fr; }
  .partner-segments { grid-template-columns: 1fr; }
}
</style>
</head>
<body>

<nav>
  <div class="nav-brand">
    <a href="{% if lang == 'en' %}/en/{% else %}/?lang=fr{% endif %}"><img src="/logo-kollder.png" alt="Kollder"></a>
  </div>
  <div class="nav-right">
    <a href="{% if lang == 'en' %}/en/{% else %}/?lang=fr{% endif %}" class="nav-link">{% if lang == 'en' %}Home{% else %}Accueil{% endif %}</a>
    <a href="{% if lang == 'en' %}/en/partners/{% else %}/fr/distributeurs/{% endif %}" class="nav-link">{% if lang == 'en' %}Partners{% else %}Distributeurs{% endif %}</a>
    <a href="{% if lang == 'en' %}/blog/?lang=en{% else %}/blog/?lang=fr{% endif %}" class="nav-link">
      {% if lang == 'en' %}Resources{% else %}Ressources{% endif %}<span class="nav-badge" id="nav-badge"></span>
    </a>
    <a href="{% if lang == 'en' %}/en/monitor/{% else %}/fr/monitor/{% endif %}" class="nav-link" style="display:inline-flex;align-items:center;gap:5px;opacity:.85;"><span style="width:7px;height:7px;border-radius:50%;background:#e85c3a;display:inline-block;animation:pulse-dot 2s ease-in-out infinite;"></span>{% if lang == 'en' %}EHS Monitor{% else %}Moniteur EHS{% endif %}</a>
    <a href="{% if lang == 'en' %}/en/#contact{% else %}/#contact{% endif %}" class="nav-devis">
      {% if lang == 'en' %}Get a quote{% else %}Obtenir un devis{% endif %}
    </a>
    <div class="lang-toggle">
      <a class="lang-btn{% if lang != 'en' %} active{% endif %}" href="{{ urlFr }}" style="text-decoration:none">FR</a>
      <a class="lang-btn{% if lang == 'en' %} active{% endif %}" href="{{ urlEn }}" style="text-decoration:none">EN</a>
    </div>
  </div>
  <button class="ham-btn" id="hamBtn" aria-label="Menu">
    <span></span><span></span><span></span>
  </button>
</nav>

<!-- Mobile overlay -->
<div class="nav-overlay" id="navOverlay">
  <div class="nav-overlay-links">
    <a class="nav-overlay-link" id="ov-home">
      <span id="ov-home-label">Accueil</span>
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
    </a>
    <a class="nav-overlay-link" id="ov-distrib">
      <span id="ov-distrib-label">Distributeurs</span>
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
    </a>
    <a class="nav-overlay-link" id="ov-blog">
      <span id="ov-blog-label">Ressources</span><span class="nav-overlay-badge" id="ov-badge"></span>
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
    </a>
    <a class="nav-overlay-link" id="ov-monitor">
      <span id="ov-monitor-label">Moniteur EHS <span style="display:inline-block;width:7px;height:7px;border-radius:50%;background:#e85c3a;margin-left:4px;vertical-align:middle;"></span></span><svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
    </a>
  </div>
  <a class="nav-overlay-cta" id="ov-cta">
    <span id="ov-cta-label">Obtenir un devis</span>
    <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
  </a>
  <div class="nav-overlay-lang">
    <a id="ov-fr" href="{{ urlFr }}">FR</a>
    <a id="ov-en" href="{{ urlEn }}">EN</a>
  </div>
</div>

{{ content | safe }}

<footer>
  <div class="footer-inner">
    <div class="footer-brand"><img src="/logo-kollder.png" alt="Kollder"></div>
    <div class="footer-note">Emergency Cooling. Anywhere.</div>
  </div>
</footer>

<script src="/lang.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
  var lang = localStorage.getItem('kollder_lang') || 'fr';
  var isFr = lang !== 'en';

  // Article count badge
  fetch('/article-count.json').then(function(r){ return r.json(); }).then(function(d){
    var cnt = (d && (d.count || d.total)) || '';
    var nb = document.getElementById('nav-badge');
    var ob = document.getElementById('ov-badge');
    if (nb && cnt) nb.textContent = cnt;
    if (ob && cnt) ob.textContent = cnt;
  }).catch(function(){});

  // Overlay links
  document.getElementById('ov-home').href = isFr ? '/?lang=fr' : '/en/';
  document.getElementById('ov-home-label').textContent = isFr ? 'Accueil' : 'Home';
  document.getElementById('ov-distrib').href = isFr ? '/fr/distributeurs/' : '/en/partners/';
  document.getElementById('ov-distrib-label').textContent = isFr ? 'Distributeurs' : 'Partners';
  document.getElementById('ov-blog').href = isFr ? '/blog/?lang=fr' : '/blog/?lang=en';
  document.getElementById('ov-blog-label').textContent = isFr ? 'Ressources' : 'Resources';
  document.getElementById('ov-monitor').href = isFr ? '/fr/monitor/' : '/en/monitor/';
  document.getElementById('ov-monitor-label').innerHTML = (isFr ? 'Moniteur EHS' : 'EHS Monitor') + ' <span style="display:inline-block;width:7px;height:7px;border-radius:50%;background:#e85c3a;margin-left:4px;vertical-align:middle;"></span>';
  document.getElementById('ov-cta').href = isFr ? '/#contact' : '/en/#contact';
  document.getElementById('ov-cta-label').textContent = isFr ? 'Obtenir un devis' : 'Get a quote';
  document.getElementById('ov-fr').className = isFr ? 'active' : '';
  document.getElementById('ov-en').className = !isFr ? 'active' : '';

  // Hamburger toggle
  var btn = document.getElementById('hamBtn');
  var overlay = document.getElementById('navOverlay');
  btn.addEventListener('click', function() {
    var isOpen = overlay.classList.toggle('open');
    btn.classList.toggle('open', isOpen);
    document.body.style.overflow = isOpen ? 'hidden' : '';
  });
  overlay.querySelectorAll('a').forEach(function(a) {
    a.addEventListener('click', function() {
      overlay.classList.remove('open');
      btn.classList.remove('open');
      document.body.style.overflow = '';
    });
  });
});
</script>

</body>
</html>
