<!DOCTYPE html>
<html lang="{% if lang == 'en' %}en{% else %}fr{% endif %}">
<head>
<!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-SF9XF8JQZK"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-SF9XF8JQZK');
</script>
<!-- Microsoft Clarity -->
<script type="text/javascript">
    (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
    })(window, document, "clarity", "script", "wy0jm2kj2r");
</script>
<meta charset="UTF-8">
<link rel="icon" type="image/x-icon" href="/favicon.ico">
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
<link rel="icon" type="image/png" sizes="192x192" href="/android-chrome-192x192.png">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title }} — Kollder</title>
<meta name="description" content="{{ description }}">
<link rel="canonical" href="https://kollder.com{{ page.url }}">
<meta property="og:title" content="{{ title }} — Kollder">
<meta property="og:description" content="{{ description }}">
<meta property="og:type" content="website">
<meta property="og:url" content="https://kollder.com{{ page.url }}">
<link rel="alternate" hreflang="fr" href="https://kollder.com/fr/distributeurs/">
<link rel="alternate" hreflang="en" href="https://kollder.com/en/partners/">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root {
  --black: #0f0f0d; --ink: #1a1a17; --white: #faf9f7;
  --cream: #f0ece4; --beige: #e8e0d4; --sand: #c8bfb0;
  --muted: #8a8278; --border: rgba(26,26,23,0.1);
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
body { background: var(--white); color: var(--ink); font-family: 'DM Sans', sans-serif; font-weight: 300; line-height: 1.7; }

/* NAV */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  display: flex; justify-content: space-between; align-items: center;
  padding: 14px 56px; background: rgba(255,255,255,0.95);
  backdrop-filter: blur(20px); border-bottom: 1px solid rgba(0,0,0,0.08);
}
.nav-brand img { height: 52px; width: auto; display: block; }
.nav-right { display: flex; align-items: center; gap: 28px; }
.nav-link {
  font-size: 13px; font-weight: 500; color: var(--muted);
  text-decoration: none; letter-spacing: 0.06em;
  display: flex; align-items: center; gap: 8px; transition: color .2s;
}
.nav-link:hover { color: var(--ink); }
.nav-link-active { color: var(--ink); }
.nav-devis {
  font-family: 'DM Sans', sans-serif; font-size: 12px; font-weight: 500;
  letter-spacing: 0.1em; text-transform: uppercase; text-decoration: none;
  padding: 9px 20px; background: var(--black); color: var(--white);
  transition: background .2s;
}
.nav-devis:hover { background: #333; }
.nav-badge {
  display: inline-flex; align-items: center; justify-content: center;
  background: var(--sand); color: var(--ink); font-size: 10px; font-weight: 500;
  padding: 1px 6px; border-radius: 10px; margin-left: 4px;
}
.lang-toggle { display: flex; border: 1px solid var(--border); }
.lang-btn {
  background: none; border: none; font-family: 'DM Sans', sans-serif;
  font-size: 12px; font-weight: 500; letter-spacing: 0.1em;
  padding: 6px 12px; cursor: pointer; color: var(--muted); transition: all .2s;
  text-decoration: none; display: inline-block;
}
.lang-btn.active { background: var(--black); color: var(--white); }

/* Hamburger */
.ham-btn {
  display: none; flex-direction: column; justify-content: center;
  gap: 5px; background: none; border: none; cursor: pointer;
  padding: 4px; z-index: 200;
}
.ham-btn span {
  display: block; width: 22px; height: 2px;
  background: var(--ink); transition: all .25s;
}
.ham-btn.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.ham-btn.open span:nth-child(2) { opacity: 0; }
.ham-btn.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

/* Mobile overlay */
.nav-overlay {
  display: none; position: fixed; inset: 0; z-index: 150;
  background: var(--white); flex-direction: column;
  padding: 90px 32px 40px;
}
.nav-overlay.open { display: flex; }
.nav-overlay-links {
  display: flex; flex-direction: column; gap: 8px; flex: 1;
}
.nav-overlay-link {
  font-size: 22px; font-weight: 400; color: var(--ink);
  text-decoration: none; padding: 14px 0;
  border-bottom: 1px solid var(--border);
  display: flex; align-items: center; justify-content: space-between;
  font-family: 'DM Serif Display', serif;
}
.nav-overlay-link:last-child { border-bottom: none; }
.nav-overlay-badge {
  display: inline-block; font-size: 10px; font-weight: 500;
  letter-spacing: 0.04em; font-family: 'DM Sans', sans-serif;
  background: var(--beige, #e8e4dc); color: var(--muted, #888);
  padding: 2px 8px; border-radius: 20px; margin-left: 8px;
  vertical-align: middle; line-height: 1.6;
}
.nav-overlay-cta {
  display: inline-flex; align-items: center; gap: 10px; margin-top: 32px;
  background: var(--black); color: var(--white); text-decoration: none;
  font-size: 13px; font-weight: 500; letter-spacing: 0.1em;
  text-transform: uppercase; padding: 16px 28px; align-self: flex-start;
}
.nav-overlay-lang {
  display: flex; gap: 0; border: 1px solid var(--border);
  margin-top: 24px; align-self: flex-start;
}
.nav-overlay-lang a {
  font-size: 12px; font-weight: 500; letter-spacing: 0.1em;
  padding: 8px 16px; text-decoration: none; color: var(--muted);
}
.nav-overlay-lang a.active { background: var(--black); color: var(--white); }

/* HERO */
.partner-hero {
  padding: 140px 56px 80px;
  background: var(--black); color: var(--white);
}
.partner-hero__inner { max-width: 860px; margin: 0 auto; }
.partner-hero h1 {
  font-family: 'DM Serif Display', serif;
  font-size: clamp(32px, 4.5vw, 56px); font-weight: 400;
  line-height: 1.1; color: var(--white); margin-bottom: 24px;
}
.partner-hero__sub {
  font-size: 17px; color: rgba(250,249,247,0.65);
  max-width: 620px; line-height: 1.65; margin-bottom: 40px;
}
.partner-btn {
  display: inline-flex; align-items: center; gap: 10px;
  background: var(--white); color: var(--black);
  font-family: 'DM Sans', sans-serif; font-size: 13px; font-weight: 500;
  letter-spacing: 0.1em; text-transform: uppercase;
  padding: 15px 28px; text-decoration: none; transition: background .2s;
}
.partner-btn:hover { background: var(--cream); }

/* SECTIONS */
.partner-section { padding: 88px 56px; }
.partner-section--alt { background: var(--cream); }
.partner-section__inner { max-width: 1100px; margin: 0 auto; }
.partner-section--narrow { max-width: 720px; }
.partner-section h2 {
  font-family: 'DM Serif Display', serif;
  font-size: clamp(26px, 3vw, 40px); font-weight: 400;
  color: var(--black); margin-bottom: 16px; line-height: 1.15;
}
.partner-section__lead {
  font-size: 16px; color: var(--muted); max-width: 640px;
  line-height: 1.7; margin-bottom: 52px;
}

/* STATS (section 2) */
.partner-stats {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 2px; background: var(--border);
}
.partner-stat {
  background: var(--white); padding: 40px 36px;
}
.partner-section--alt .partner-stat { background: var(--cream); }
.partner-stat__figure {
  font-family: 'DM Serif Display', serif;
  font-size: 48px; color: var(--black); line-height: 1; margin-bottom: 6px;
}
.partner-stat__label {
  font-size: 11px; font-weight: 500; letter-spacing: 0.18em;
  text-transform: uppercase; color: var(--muted); margin-bottom: 18px;
}
.partner-stat p { font-size: 14px; color: var(--muted); line-height: 1.65; }

/* SEGMENTS (section 3) */
.partner-segments {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 24px; margin-top: 8px;
}
.partner-segment {
  border: 1px solid var(--border); background: var(--white); overflow: hidden;
}
.partner-section--alt .partner-segment { background: var(--cream); }
.partner-segment__img { width: 100%; aspect-ratio: 16/9; overflow: hidden; background: var(--beige); }
.partner-segment__img img { width: 100%; height: 100%; object-fit: cover; display: block; filter: grayscale(20%); transition: filter .3s; }
.partner-segment:hover .partner-segment__img img { filter: grayscale(0%); }
.partner-segment__img--placeholder {
  display: flex; align-items: center; justify-content: center;
  background: var(--ink);
}
.partner-segment__img--placeholder span {
  font-size: 11px; font-weight: 500; letter-spacing: 0.12em;
  text-transform: uppercase; color: rgba(250,249,247,0.35);
}
.partner-segment__body { padding: 24px; }
.partner-segment h3 {
  font-family: 'DM Sans', sans-serif; font-size: 15px; font-weight: 500;
  color: var(--black); margin-bottom: 8px;
}
.partner-segment p { font-size: 13px; color: var(--muted); line-height: 1.65; }

/* PRODUCT DARK SECTION (section 4) */
.partner-section--dark { background: var(--black); }
.partner-section--dark h2 { color: var(--white); }
.partner-section__h2--light { color: var(--white) !important; }
.partner-section__lead--light { color: rgba(250,249,247,0.5) !important; }
.partner-product-grid {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 2px; background: rgba(255,255,255,0.06); margin-top: 8px;
}
.partner-product-card { background: var(--black); overflow: hidden; }
.partner-product-card img { width: 100%; aspect-ratio: 4/3; object-fit: cover; display: block; filter: grayscale(30%) brightness(0.75); }
.partner-product-card__body { padding: 28px 24px; }
.partner-product-card__kicker {
  display: block; font-size: 11px; font-weight: 500; letter-spacing: 0.14em;
  text-transform: uppercase; color: var(--sand); margin-bottom: 10px;
}
.partner-product-card h3 {
  font-family: 'DM Serif Display', serif; font-size: 18px; font-weight: 400;
  color: var(--white); line-height: 1.25; margin-bottom: 10px;
}
.partner-product-card p { font-size: 13px; color: rgba(250,249,247,0.45); line-height: 1.65; }

/* MERGED APPLY SECTION (section 6) */
.partner-apply {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 72px; align-items: start;
}
.partner-apply__left h2 { margin-bottom: 12px; }
.partner-apply__left > p { font-size: 15px; color: var(--muted); margin-bottom: 32px; line-height: 1.65; }
.partner-apply__criteria { margin-top: 8px; }
.partner-apply__criteria-title {
  font-size: 12px; font-weight: 500; letter-spacing: 0.1em;
  text-transform: uppercase; color: var(--muted); margin-bottom: 16px;
}
.partner-apply__criteria-note {
  margin-top: 20px; font-size: 13px; color: var(--muted); font-style: italic;
}

@media (max-width: 900px) {
  .partner-apply { grid-template-columns: 1fr; gap: 40px; }
  .partner-product-grid { grid-template-columns: 1fr; }
}

/* BENEFITS (section 5) */
.partner-benefits {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 24px; margin-top: 8px;
}
.partner-benefit {
  border-top: 2px solid var(--ink); padding-top: 20px;
}
.partner-benefit--wide { grid-column: 1 / -1; border-top-color: var(--sand); padding-top: 20px; }
.partner-benefit strong { display: block; font-size: 15px; font-weight: 500; color: var(--black); margin-bottom: 8px; }
.partner-benefit p { font-size: 14px; color: var(--muted); line-height: 1.65; }
.partner-note {
  margin-top: 40px; font-size: 13px; color: var(--muted);
  font-style: italic; border-top: 1px solid var(--border); padding-top: 20px;
}

/* CRITERIA (section 6) */
.partner-criteria {
  list-style: none; padding: 0; margin: 0 0 28px;
  display: flex; flex-direction: column; gap: 14px;
}
.partner-criteria li {
  font-size: 15px; color: var(--ink); padding-left: 20px; position: relative; line-height: 1.55;
}
.partner-criteria li::before {
  content: '—'; position: absolute; left: 0; color: var(--sand);
}
.partner-section--narrow > p {
  font-size: 15px; color: var(--muted); line-height: 1.65;
}

/* FORM (section 7) */
.partner-form { margin-top: 36px; display: flex; flex-direction: column; gap: 20px; }
.partner-form__row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
.partner-form__field { display: flex; flex-direction: column; gap: 6px; }
.partner-form__field label {
  font-size: 12px; font-weight: 500; letter-spacing: 0.1em;
  text-transform: uppercase; color: var(--muted);
}
.partner-form__field input,
.partner-form__field textarea {
  border: 1px solid var(--border); background: var(--white);
  padding: 12px 14px; font-family: 'DM Sans', sans-serif;
  font-size: 15px; font-weight: 300; color: var(--ink);
  outline: none; transition: border-color .2s; resize: vertical;
}
.partner-form__field input:focus,
.partner-form__field textarea:focus { border-color: var(--ink); }
.partner-form .partner-btn {
  background: var(--black); color: var(--white);
  align-self: flex-start; margin-top: 8px;
}
.partner-form .partner-btn:hover { background: var(--ink); }

/* FOOTER — identique article.njk */
footer {
  background: #000; border-top: 1px solid rgba(255,255,255,0.08); padding: 40px 56px;
}
.footer-inner {
  max-width: 1240px; margin: 0 auto;
  display: flex; justify-content: space-between; align-items: center; gap: 24px; flex-wrap: wrap;
}
.footer-brand img { height: 52px; width: auto; display: block; filter: invert(1); }
.footer-note { font-size: 12px; color: rgba(250,249,247,0.25); letter-spacing: 0.04em; }

/* RESPONSIVE */
@media (max-width: 768px) {
  nav { padding: 14px 24px; }
  .nav-right { display: none; }
  .ham-btn { display: flex; }
  .partner-hero { padding: 110px 24px 60px; }
  .partner-section { padding: 64px 24px; }
  footer { padding: 32px 24px; }
  .partner-form__row { grid-template-columns: 1fr; }
  .partner-stats { grid-template-columns: 1fr; }
  .partner-segments { grid-template-columns: 1fr; }
}
</style>
</head>
<body>

<nav>
  <div class="nav-brand">
    <a href="{% if lang == 'en' %}/en/{% else %}/?lang=fr{% endif %}"><img src="/logo-kollder.png" alt="Kollder"></a>
  </div>
  <div class="nav-right">
    <a href="{% if lang == 'en' %}/en/{% else %}/?lang=fr{% endif %}" class="nav-link">{% if lang == 'en' %}Home{% else %}Accueil{% endif %}</a>
    <a href="{% if lang == 'en' %}/en/partners/{% else %}/fr/distributeurs/{% endif %}" class="nav-link nav-link-active">{% if lang == 'en' %}Partners{% else %}Distributeurs{% endif %}</a>
    <a href="{% if lang == 'en' %}/blog/?lang=en{% else %}/blog/?lang=fr{% endif %}" class="nav-link">
      {% if lang == 'en' %}Resources{% else %}Ressources{% endif %}<span class="nav-badge" id="nav-badge"></span>
    </a>
    <a href="{% if lang == 'en' %}/en/#contact{% else %}/#contact{% endif %}" class="nav-devis">
      {% if lang == 'en' %}Get a quote{% else %}Obtenir un devis{% endif %}
    </a>
    <div class="lang-toggle">
      <a class="lang-btn{% if lang != 'en' %} active{% endif %}" href="/fr/distributeurs/" style="text-decoration:none">FR</a>
      <a class="lang-btn{% if lang == 'en' %} active{% endif %}" href="/en/partners/" style="text-decoration:none">EN</a>
    </div>
  </div>
  <button class="ham-btn" id="hamBtn" aria-label="Menu">
    <span></span><span></span><span></span>
  </button>
</nav>

<!-- Mobile overlay -->
<div class="nav-overlay" id="navOverlay">
  <div class="nav-overlay-links">
    <a class="nav-overlay-link" id="ov-home">
      <span id="ov-home-label">Accueil</span>
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
    </a>
    <a class="nav-overlay-link" id="ov-distrib">
      <span id="ov-distrib-label">Distributeurs</span>
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
    </a>
    <a class="nav-overlay-link" id="ov-blog">
      <span id="ov-blog-label">Ressources</span><span class="nav-overlay-badge" id="ov-badge"></span>
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
    </a>
  </div>
  <a class="nav-overlay-cta" id="ov-cta">
    <span id="ov-cta-label">Obtenir un devis</span>
    <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
  </a>
  <div class="nav-overlay-lang">
    <a id="ov-fr" href="/fr/distributeurs/">FR</a>
    <a id="ov-en" href="/en/partners/">EN</a>
  </div>
</div>

{{ content | safe }}

<footer>
  <div class="footer-inner">
    <div class="footer-brand"><img src="/logo-kollder.png" alt="Kollder"></div>
    <div class="footer-note">Emergency Cooling. Anywhere.</div>
  </div>
</footer>

<script src="/lang.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
  var lang = localStorage.getItem('kollder_lang') || 'fr';
  var isFr = lang !== 'en';

  // Article count badge
  fetch('/article-count.json').then(function(r){ return r.json(); }).then(function(d){
    var cnt = (d && (d.count || d.total)) || '';
    var nb = document.getElementById('nav-badge');
    var ob = document.getElementById('ov-badge');
    if (nb && cnt) nb.textContent = cnt;
    if (ob && cnt) ob.textContent = cnt;
  }).catch(function(){});

  // Overlay links
  document.getElementById('ov-home').href = isFr ? '/?lang=fr' : '/en/';
  document.getElementById('ov-home-label').textContent = isFr ? 'Accueil' : 'Home';
  document.getElementById('ov-distrib').href = isFr ? '/fr/distributeurs/' : '/en/partners/';
  document.getElementById('ov-distrib-label').textContent = isFr ? 'Distributeurs' : 'Partners';
  document.getElementById('ov-blog').href = isFr ? '/blog/?lang=fr' : '/blog/?lang=en';
  document.getElementById('ov-blog-label').textContent = isFr ? 'Ressources' : 'Resources';
  document.getElementById('ov-cta').href = isFr ? '/#contact' : '/en/#contact';
  document.getElementById('ov-cta-label').textContent = isFr ? 'Obtenir un devis' : 'Get a quote';
  document.getElementById('ov-fr').className = isFr ? 'active' : '';
  document.getElementById('ov-en').className = !isFr ? 'active' : '';

  // Hamburger toggle
  var btn = document.getElementById('hamBtn');
  var overlay = document.getElementById('navOverlay');
  btn.addEventListener('click', function() {
    var isOpen = overlay.classList.toggle('open');
    btn.classList.toggle('open', isOpen);
    document.body.style.overflow = isOpen ? 'hidden' : '';
  });
  overlay.querySelectorAll('a').forEach(function(a) {
    a.addEventListener('click', function() {
      overlay.classList.remove('open');
      btn.classList.remove('open');
      document.body.style.overflow = '';
    });
  });
});
</script>

</body>
</html>
