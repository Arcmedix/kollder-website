<script>
(function() {
  var current = 0;
  var track = document.getElementById('heroCarouselTrack');
  if (!track) return;
  var dots = document.querySelectorAll('#heroCarousel .carousel-dot');
  var thumbs = document.querySelectorAll('.thumb-strip .thumb');
  var timer;
  function goTo(n) {
    current = (n + 4) % 4;
    track.style.transform = 'translateX(-' + (current * 25) + '%)';
    dots.forEach(function(d,i){ d.classList.toggle('active', i===current); });
    thumbs.forEach(function(t,i){ t.classList.toggle('active', i===current); });
    clearInterval(timer);
    timer = setInterval(function(){ goTo(current+1); }, 4000);
  }
  window.heroGoTo = goTo;
  timer = setInterval(function(){ goTo(current+1); }, 4000);
})();

(function() {
  var track = document.getElementById('pcFieldTrack');
  var wrap = document.getElementById('pcFieldTrackWrap');
  var dots = document.querySelectorAll('#pcFieldDots .field-dot');
  if (!track) return;

  var current = 0;
  var total = track.children.length;

  function getSlideWidth() {
    var slide = track.children[0];
    if (!slide) return 540;
    var style = window.getComputedStyle(track);
    var gap = parseInt(style.gap || style.columnGap || '20') || 20;
    return slide.offsetWidth + gap;
  }

  window.pcFieldGoTo = function(n) {
    current = Math.max(0, Math.min(n, total - 1));
    track.style.transform = 'translateX(-' + (current * getSlideWidth()) + 'px)';
    dots.forEach(function(d, i) {
      d.classList.toggle('active', i === current);
    });
  };

  window.pcFieldStep = function(dir) {
    var next = current + dir;
    if (next < 0) next = total - 1;
    if (next >= total) next = 0;
    window.pcFieldGoTo(next);
  };

  var startX = 0, dragging = false;
  wrap.addEventListener('mousedown', function(e) {
    dragging = true; startX = e.pageX;
    wrap.style.cursor = 'grabbing';
  });
  document.addEventListener('mouseup', function(e) {
    if (!dragging) return;
    dragging = false;
    wrap.style.cursor = 'grab';
    var diff = startX - e.pageX;
    if (Math.abs(diff) > 60) window.pcFieldStep(diff > 0 ? 1 : -1);
    else window.pcFieldGoTo(current);
  });
  wrap.addEventListener('touchstart', function(e) {
    startX = e.touches[0].pageX;
  }, { passive: true });
  wrap.addEventListener('touchend', function(e) {
    var diff = startX - e.changedTouches[0].pageX;
    if (Math.abs(diff) > 50) window.pcFieldStep(diff > 0 ? 1 : -1);
  }, { passive: true });

  var timer = setInterval(function() { window.pcFieldStep(1); }, 5000);
  wrap.addEventListener('mouseenter', function() { clearInterval(timer); });
  wrap.addEventListener('mouseleave', function() {
    clearInterval(timer);
    timer = setInterval(function() { window.pcFieldStep(1); }, 5000);
  });
})();
</script>
